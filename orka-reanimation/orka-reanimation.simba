(**
 * GetPrayerXP
 *
 * Returns the prayer experience gained for reanimating a specific head.
 * Values based on OSRS Wiki.
 *
 * @param headType  The head enum
 * @return          Experience points
 *)
function GetPrayerXP(headType: EHeadType): Int32;
begin
  case headType of
    HEAD_ABYSSAL:     Result := 1300;
    HEAD_AVIANSIE:    Result := 1234;
    HEAD_BEAR:        Result := 480;
    HEAD_BLOODVELD:   Result := 1040;
    HEAD_CHAOS_DRUID: Result := 584;
    HEAD_DAGANNOTH:   Result := 936;
    HEAD_DEMON:       Result := 1170;
    HEAD_DOG:         Result := 520;
    HEAD_DRAGON:      Result := 1560;
    HEAD_ELF:         Result := 754;
    HEAD_GIANT:       Result := 650;
    HEAD_GOBLIN:      Result := 130;
    HEAD_HELLHOUND:   Result := 1200;
    HEAD_HORROR:      Result := 832;
    HEAD_IMP:         Result := 286;
    HEAD_KALPHITE:    Result := 884;
    HEAD_MINOTAUR:    Result := 364;
    HEAD_MONKEY:      Result := 182;
    HEAD_OGRE:        Result := 716;
    HEAD_SCORPION:    Result := 454;
    HEAD_TROLL:       Result := 780;
    HEAD_TZHAAR:      Result := 1104;
    HEAD_UNICORN:     Result := 494;
  end;
end;

(**
 * IsLargeMonster
 *
 * Checks if the head type belongs to a large monster (3x3 or bigger).
 * Used for offsetting click points and determining attack range.
 *
 * @param headType  The head enum to check
 * @return          True if the monster is large
 *)
function IsLargeMonster(headType: EHeadType): Boolean;
begin
  Result := headType in [
    HEAD_AVIANSIE, HEAD_BLOODVELD, HEAD_DEMON,
    HEAD_DRAGON, HEAD_GIANT, HEAD_HELLHOUND, HEAD_HORROR,
    HEAD_KALPHITE, HEAD_OGRE
  ];
end;

(**
 * GetPotionItemName
 *
 * Returns the full item name for a given potion type.
 * Currently supports 1-dose potions.
 *
 * @param potion  The potion enum type
 * @return        The full string name of the potion item
 *)
function GetPotionItemName(potion: EPotionType): String;
begin
  case potion of
    POTION_COMBAT:         Result := 'Combat potion(1)';
    POTION_ATTACK:         Result := 'Attack potion(1)';
    POTION_STRENGTH:       Result := 'Strength potion(1)';
    POTION_SUPER_ATTACK:   Result := 'Super attack(1)';
    POTION_SUPER_STRENGTH: Result := 'Super strength(1)';
    POTION_SUPER_COMBAT:   Result := 'Super combat potion(1)';
    POTION_RANGING:        Result := 'Ranging potion(1)';
  end;
end;

// -----------------------------------------------------------------------------
// Helper Functions
// -----------------------------------------------------------------------------

(**
 * WriteDebug
 *
 * Output a debug message to the console if VERBOSE_LOGGING is enabled.
 * Formats with timestamp and script prefix.
 *
 * @param msg  The message to log
 *)
procedure WriteDebug(msg: String);
begin
  if VERBOSE_LOGGING then
    WriteLn(SRL.TimeStamp(), ':[Reanimation]: ', msg);
end;

(**
 * AttemptSpec
 *
 * Attempts to use the special attack if energy permits.
 * Learns the spec cost dynamically if not already known.
 * Includes randomization to mimic human behavior.
 *)
procedure TReanimationBot.AttemptSpec();
var
  StartLevel, EndLevel: Int32;
  CurrentSpec: Int32;
begin
  if not Self.UseSpecs then
    Exit;

  if not Minimap.IsSpecWeapon() then
    Exit;

  CurrentSpec := Minimap.GetSpecLevel();

  // Randomize spec usage unless we are learning cost
  if (Self.WeaponSpecCost > 0) and (not SRL.Dice(SPEC_USE_CHANCE)) then
    Exit;

  if (Self.WeaponSpecCost > 0) then
  begin
    if CurrentSpec < Self.WeaponSpecCost then
    begin
      WriteDebug('AttemptSpec | Not enough spec energy (' + ToStr(CurrentSpec) + '% < ' + ToStr(Self.WeaponSpecCost) + '%)');
      Exit;
    end;
  end;

  Minimap.EnableSpec(0); // Handles "already enabled" check internally
  Wait(200, 300);

  // Learning Logic: Deduce spec cost by observing bar drop
  if (Self.WeaponSpecCost = 0) then
    begin
       // Check immediately
       EndLevel := Minimap.GetSpecLevel();

       if (StartLevel > EndLevel) then
       begin
         // Case A: Immediate drop (e.g. Gmaul, or lag handled)
         Self.WeaponSpecCost := StartLevel - EndLevel;
       end
       else
       begin
         // Case B: Delayed drop (most weapons like DDS queue the spec).
         // We wait briefly (up to 1.5s) to catch the drop before regen interferes.
         if WaitUntil(Minimap.GetSpecLevel() < StartLevel, 100, 10000) then
         begin
            EndLevel := Minimap.GetSpecLevel();
            Self.WeaponSpecCost := StartLevel - EndLevel;
            WriteDebug('AttemptSpec | Learned Spec Cost: ' + ToStr(Self.WeaponSpecCost) + '%');
         end
         else
            WriteDebug('AttemptSpec | Failed to learn cost (no drop detected)');
       end;
    end
    else
    begin
      // If we know the cost, but level didn't drop, it might be a delayed spec (DDS)
      EndLevel := Minimap.GetSpecLevel();
      if (StartLevel = EndLevel) then
        WriteDebug('AttemptSpec | Spec Queued')
      else
        WriteDebug('AttemptSpec | Spec Used');
    end;
end;

(**
 * SafeCastSpell
 *
 * Casts a spell safely by verifying the spellbook is open and UpText matches.
 *
 * @param spell           The spell to cast
 * @param expectedUpText  Array of strings to verify correct spell target
 * @return                True if cast was successful
 *)
function TReanimationBot.SafeCastSpell(spell: ERSSpell; expectedUpText: TStringArray): Boolean;
var
  box: TBox;
  selectedSlot: Int32;
begin
  if not Magic.Open() then
    Exit(False);

  // Use FindSpell to locate the box
  if not Magic.FindSpell(spell, box) then
  begin
    WriteDebug('SafeCastSpell | Could not find spell: ' + ToStr(spell));
    Exit(False);
  end;

  Mouse.Move(box);
  Wait(50, 150);

  // Verify UpText
  if not MainScreen.IsUpText(expectedUpText, 200) then
  begin
    if MainScreen.IsUpText(['Use Ensouled']) then
    begin
      WriteDebug('SafeCastSpell | Item selected accidentally. Deselecting...');
      selectedSlot := Inventory.GetSelectedSlot();
      if selectedSlot > -1 then
      begin
        Inventory.ClickSlot(selectedSlot);
        WaitUntil(Inventory.GetSelectedSlot() = -1, 200, 2000);
      end;
      Exit(Self.SafeCastSpell(spell, expectedUpText));
    end;

    WriteDebug('SafeCastSpell | UpText mismatch. Found: ' + MainScreen.GetUpText());
    Exit(False);
  end;

  Mouse.Click(MOUSE_LEFT);
  Result := WaitUntil(Magic.SpellWasCast(spell), 300, 2000);
end;

(**
 * Location Checks
 *
 * Simple boolean checks to verify player position.
 *)

(**
 * IsInArceuusArea
 *
 * Checks if player is within the general Arceuus reanimation area.
 *
 * @return True if in Arceuus area
 *)
function IsInArceuusArea(): Boolean;
var
  pos: TPoint;
begin
  pos := Map.Position();
  Result := pos.InBox(ARCEUUS_AREA);
end;

(**
 * IsInCraftingGuild
 *
 * Checks if player is within the Crafting Guild.
 *
 * @return True if in Crafting Guild
 *)
function IsInCraftingGuild(): Boolean;
var
  pos: TPoint;
begin
  pos := Map.Position();
  Result := pos.InBox(CRAFTING_GUILD_BOX);
end;

(**
 * IsAtArceuusLibrary
 *
 * Checks if player is at the Arceuus Library teleport spot.
 *
 * @return True if at Arceuus Library
 *)
function IsAtArceuusLibrary(): Boolean;
var
  pos: TPoint;
begin
  pos := Map.Position();
  Result := pos.InBox(ARCEUUS_LIBRARY_BOX);
end;

(**
 * IsInFeroxEnclave
 *
 * Checks if player is within the Ferox Enclave area.
 *
 * @return True if in Ferox Enclave
 *)
function IsInFeroxEnclave(): Boolean;
var
  pos: TPoint;
begin
  pos := Map.Position();
  Result := pos.InBox(FEROX_ENCLAVE_BOX);
end;

(**
 * HasRingOfDuelingEquipped
 *
 * Checks if any charge of Ring of dueling is equipped.
 *
 * @return True if equipped
 *)
function HasRingOfDuelingEquipped(): Boolean;
begin
  Result := Equipment.ContainsAny(['Ring of dueling(8)', 'Ring of dueling(7)',
    'Ring of dueling(6)', 'Ring of dueling(5)', 'Ring of dueling(4)',
    'Ring of dueling(3)', 'Ring of dueling(2)', 'Ring of dueling(1)']);
end;

(**
 * CheckRingCrumbled
 *
 * Checks the chat for the message indicating the Ring of Dueling has crumbled.
 *
 * @return True if message found
 *)
function CheckRingCrumbled(): Boolean;
begin
  // Check if the chat contains the crumbled message
  Result := Chat.FindMessage(RING_CRUMBLED_MESSAGE, [CHAT_COLOR_PURPLE]);
end;

// -----------------------------------------------------------------------------
// Stats Report
// -----------------------------------------------------------------------------

(**
 * Report
 *
 * Displays the runtime progress report in the debug console.
 * Shows XP rates, kill counts, and break information.
 *)
procedure TReanimationBot.Report();
var
  RunTime: Int64;
  PrayerXP, PrayerXPPerHour, KillsPerHour: Int32;
  leftCol, rightCol: String;
  bannerWidth: Int32 = 59;
  separator: String;
  title: String;
  TimeSinceLastBreak: Int64;
begin
  RunTime := GetTimeRunning();

  // Calculate Prayer XP based on confirmed kills (accurate XP)
  PrayerXP := Self.MonstersKilled * GetPrayerXP(Self.HeadType);

  if RunTime > 0 then
  begin
    PrayerXPPerHour := Round(PrayerXP / (RunTime / 3600000));
    KillsPerHour := Round((Self.MonstersKilled) / (RunTime / 3600000));
  end
  else
  begin
    PrayerXPPerHour := 0;
    KillsPerHour := 0;
  end;

  separator := '|' + StringOfChar('=', bannerWidth - 2) + '|';
  title := SCRIPT_NAME;
  title := '|' + PadR(PadL(title, (bannerWidth - 2 + Length(title)) div 2, ' '), bannerWidth - 2, ' ') + '|';

  WriteLn(separator);
  WriteLn(title);
  WriteLn(separator);

  // Row 1: Runtime | Next break
  leftCol := 'Runtime: ' + SRL.MsToTime(RunTime, Time_Short);
  if Length(Antiban.Breaks) > 0 then
    rightCol := 'Next break: ' + SRL.MsToTime(Max(0, Round(Antiban.Breaks[0].NextAtTime - RunTime)), Time_Short)
  else
    rightCol := 'Next break: N/A';
  WriteLn('| ' + PadR(leftCol, 26, ' ') + ' | ' + PadR(rightCol, 26, ' ') + ' |');

  // Row 2: Monsters killed | Time since last break
  leftCol := 'Kills: ' + ToString(Self.MonstersKilled);
  if Self.LastBreakEndTime > 0 then
  begin
    TimeSinceLastBreak := RunTime - Self.LastBreakEndTime;
    rightCol := 'Since last break: ' + SRL.MsToTime(TimeSinceLastBreak, Time_Short);
  end
  else
    rightCol := 'Since last break: N/A';
  WriteLn('| ' + PadR(leftCol, 26, ' ') + ' | ' + PadR(rightCol, 26, ' ') + ' |');

  // Row 3: Kills/Hr | Total break time
  leftCol := 'Kills/Hr: ' + ToString(KillsPerHour);
  if Self.TotalBreakTime > 0 then
    rightCol := 'Total break time: ' + SRL.MsToTime(Self.TotalBreakTime, Time_Short)
  else
    rightCol := 'Total break time: N/A';
  WriteLn('| ' + PadR(leftCol, 26, ' ') + ' | ' + PadR(rightCol, 26, ' ') + ' |');

  // Row 4: Prayer XP | Next Sleep
  leftCol := 'Prayer XP: ' + ToString(PrayerXP);
  if Length(Antiban.Sleeps) > 0 then
    rightCol := 'Next sleep: ' + SRL.MsToTime(Max(0, Round(Antiban.Sleeps[0].NextAtTime - RunTime)), Time_Short)
  else
    rightCol := 'Next sleep: N/A';
  WriteLn('| ' + PadR(leftCol, 26, ' ') + ' | ' + PadR(rightCol, 26, ' ') + ' |');

  // Row 5: Prayer XP/Hr | Shutdown
  leftCol := 'Prayer XP/Hr: ' + ToString(PrayerXPPerHour);
  if WLSettings.MaxTime > 0 then
    rightCol := 'Shutdown: ' + SRL.MsToTime(Max(0, WLSettings.MaxTime - RunTime), Time_Short)
  else
    rightCol := 'Shutdown: N/A';
  WriteLn('| ' + PadR(leftCol, 26, ' ') + ' | ' + PadR(rightCol, 26, ' ') + ' |');

  // Row 6: Heads used | Next BH run
  leftCol := 'Heads used: ' + ToString(Self.HeadsUsed);
  if Self.DoBHRuns then
    rightCol := 'Next BH: ' + SRL.MsToTime(BirdHouseRunner.ScriptIntervalTimer.TimeRemaining(), Time_Short)
  else
    rightCol := 'BH Runs: Disabled';
  WriteLn('| ' + PadR(leftCol, 26, ' ') + ' | ' + PadR(rightCol, 26, ' ') + ' |');

  WriteLn(separator);

  title := 'Orka Scripts';
  title := '|' + PadR(PadL(title, (bannerWidth - 2 + Length(title)) div 2, ' '), bannerWidth - 2, ' ') + '|';
  WriteLn(title);
  WriteLn(separator);
end;

// -----------------------------------------------------------------------------
// Break Callbacks
// -----------------------------------------------------------------------------

(**
 * OnBreakStart
 *
 * Callback triggered when a break starts.
 * Records the start time for stats reporting.
 *
 * @param Task  The break task info
 *)
procedure OnBreakStart(Task: PBreakTask);
begin
  Task;
  Bot.LastBreakStartTime := GetTimeRunning();
end;

(**
 * OnBreakEnd
 *
 * Callback triggered when a break ends.
 * Updates total break time calculation.
 *
 * @param Task  The break task info
 *)
procedure OnBreakEnd(Task: PBreakTask);
var
  BreakDuration: Int64;
begin
  Task;
  Bot.LastBreakEndTime := GetTimeRunning();
  BreakDuration := Bot.LastBreakEndTime - Bot.LastBreakStartTime;
  Bot.TotalBreakTime := Bot.TotalBreakTime + BreakDuration;
end;

// -----------------------------------------------------------------------------
// Antiban Setup
// -----------------------------------------------------------------------------

(**
 * TAntiban.Setup
 *
 * Configures antiban skills, zoom levels, and break callbacks.
 * Disables chat task to prevent missing game messages.
 *)
procedure TAntiban.Setup(); override;
begin
  Self.Skills := [ERSSkill.PRAYER, ERSSkill.MAGIC, ERSSkill.TOTAL];
  Self.MinZoom := 15;
  Self.MaxZoom := 50;

  Self.OnStartBreak := @OnBreakStart;
  Self.OnFinishBreak := @OnBreakEnd;

  // Disable random chat tab switching to prevent missing game messages
  WLSettings.GetObject('antiban').getJSONObject('tasks').Put('chat', False);

  inherited;
end;

// -----------------------------------------------------------------------------
// Birdhouse Runner Overrides
// -----------------------------------------------------------------------------

(**
 * TBirdHouseInclude.OnStart
 *
 * Prepares for a birdhouse run:
 * - Teleports to bank
 * - Withdraws necessary items (logs, seeds, hammer, chisel, clockwork)
 * - Equips Digsite pendant
 * - Handles Ring of Dueling replacement if at Ferox
 *
 * @return True if preparation successful
 *)
function TBirdHouseInclude.OnStart(): Boolean; override;
var
  i: Int32;
  ring: TRSBankItem;
begin
  WriteDebug('BirdHouseRunner.OnStart | Starting birdhouse run preparation...');

  // Pause antiban tasks during birdhouse run
  for i := 0 to High(Antiban.Tasks) do
    Antiban.Tasks[i].Countdown.Pause();

  // Update log type if using best log
  if Self.AlwaysUseBestLog then
  begin
    Self.SuggestedLogType := BirdHouseRunner.GetLogForHunterLevel(Stats.GetLevel(ERSSkill.HUNTER));
    if Self.LogType <> Self.SuggestedLogType then
      Self.LogType := Self.SuggestedLogType;
  end;

  // Teleport to Bank
  WriteDebug('BirdHouseRunner.OnStart | Teleporting to Bank...');
  if not Bot.TeleportToBank() then
  begin
    WriteDebug('BirdHouseRunner.OnStart | Failed to teleport to Bank');
    Exit(False);
  end;

  // Check ring status before opening bank (to avoid closing it later)
  if (Bot.BankLocation = EBankLocation.BANK_FEROX_ENCLAVE) and (not HasRingOfDuelingEquipped()) then
  begin
      WriteDebug('BirdHouseRunner.OnStart | Ring of Dueling missing, will withdraw new one...');
      Bot.NeedsNewRing := True;
  end;

  // Open bank
  for i := 1 to 5 do
  begin
    if Bank.IsOpen() then Break;

    if Bot.OpenBank() then
    begin
      if WaitUntil(Bank.IsOpen(), 200, 5000) then
      begin
        Wait(500, 1000); // Stabilize
        if Bank.IsOpen() then Break; // Still open? Good.
      end;
    end;

    WriteDebug('BirdHouseRunner.OnStart | Failed to open/keep bank open, retrying (' + ToStr(i) + '/5)...');
    Wait(1000, 2000);
  end;

  if not Bank.IsOpen() then
  begin
    WriteDebug('BirdHouseRunner.OnStart | Failed to open bank');
    Exit(False);
  end;

  // Deposit ensouled heads if any in inventory
  if Inventory.ContainsItem(Bot.HeadItem) then
  begin
    WriteDebug('BirdHouseRunner.OnStart | Depositing ensouled heads...');
    Bank.DepositItem(Bot.HeadItem, True);
    Wait(500, 750);
    Bot.HeadCount := 0;  // Reset count after depositing
  end;

  // Ensure Ring of Dueling if using Ferox Enclave
  if Bot.BankLocation = EBankLocation.BANK_FEROX_ENCLAVE then
  begin
    if Bot.NeedsNewRing then
    begin
      WriteDebug('BirdHouseRunner.OnStart | Withdrawing new Ring of Dueling...');
      ring := TRSBankItem.Setup('Ring of dueling(8)', 1);
      if Bank.WithdrawItem(ring, False) then
      begin
        Wait(600, 900);
        Bank.Close();
        WaitUntil(not Bank.IsOpen(), 200, 3000);

        if Inventory.ClickItem('Ring of dueling(8)', 'Wear') then
        begin
          WriteDebug('BirdHouseRunner.OnStart | Equipped Ring of Dueling');
          Wait(600, 900);
          Bot.NeedsNewRing := False;
        end;

        // Re-open bank
        for i := 1 to 5 do
        begin
          if Bank.IsOpen() then Break;

          if Bot.OpenBank() then
          begin
            if WaitUntil(Bank.IsOpen(), 200, 5000) then
            begin
              Wait(500, 1000);
              if Bank.IsOpen() then Break;
            end;
          end;
          WriteDebug('BirdHouseRunner.OnStart | Failed to re-open/keep bank open, retrying (' + ToStr(i) + '/5)...');
          Wait(1000, 2000);
        end;

        if not Bank.IsOpen() then
        begin
           WriteDebug('BirdHouseRunner.OnStart | Failed to re-open bank');
           Exit(False);
        end;
      end;
    end;
  end;

  // Final check before withdrawing items
  if not Bank.IsOpen() then
  begin
    WriteDebug('BirdHouseRunner.OnStart | Bank closed unexpectedly! Attempting to recover...');
    if Bot.OpenBank() then
    begin
       WaitUntil(Bank.IsOpen(), 200, 3000);
       Wait(500, 800);
    end;
  end;

  // Withdraw birdhouse items
  if not Self.WithdrawNextRun() then
  begin
    WriteDebug('BirdHouseRunner.OnStart | Failed to withdraw birdhouse items. Bank Open: ' + BoolToStr(Bank.IsOpen()));
    if Bank.IsOpen() then
       WriteDebug('BirdHouseRunner.OnStart | Bank was open but withdraw failed. Check logs/seeds.');

    Bank.Close();
    BirdHouseRunner.IsDisabled := True;
    Exit(False);
  end;

  Bank.Close();
  WaitUntil(not Bank.IsOpen(), 200, 3000);

  // Adjust camera zoom before teleporting
  WriteDebug('BirdHouseRunner.OnStart | Setting random zoom (10-20) for Fossil Island...');
  Options.SetZoomLevel(Random(10, 20));
  Wait(300, 500);

  WriteDebug('BirdHouseRunner.OnStart | Ready for birdhouse run');

  // Manually teleport to island to ensure we can wait for load
  if Self.TeleportToIsland() then
  begin
    WriteDebug('BirdHouseRunner.OnStart | Waiting extra time for Fossil Island load...');
    Wait(2500, 3500);
  end;

  Result := True;
end;

(**
 * TBirdHouseInclude.OnComplete
 *
 * Finalizes the birdhouse run:
 * - Teleports back to bank
 * - Deposits loot
 * - Resets position flags for main reanimation loop
 *)
procedure TBirdHouseInclude.OnComplete(); override;
var
  i: Int32;
begin
  WriteDebug('BirdHouseRunner.OnComplete | Finishing birdhouse run...');

  // Handle any chat continues
  if Chat.HasContinue() then
    Chat.ClickContinue();

  // Teleport back to Bank
  WriteDebug('BirdHouseRunner.OnComplete | Teleporting back to Bank...');
  if not Bot.TeleportToBank() then
  begin
    WriteDebug('BirdHouseRunner.OnComplete | Failed to teleport, trying again...');
    Wait(2000, 3000);
    Bot.TeleportToBank();
  end;

  // Open bank
  for i := 1 to 5 do
  begin
    if Bank.IsOpen() then Break;

    if Bot.OpenBank() then
    begin
      if WaitUntil(Bank.IsOpen(), 200, 5000) then
      begin
        Wait(500, 1000);
        if Bank.IsOpen() then Break;
      end;
    end;
    WriteDebug('BirdHouseRunner.OnComplete | Failed to open/keep bank open, retrying (' + ToStr(i) + '/5)...');
    Wait(1000, 2000);
  end;

  if Bank.IsOpen() then
  begin
    Wait(500, 750);

    // Deposit trash items from birdhouse run, keep essentials
    Bot.ManageInventory();

    Bank.Close();
    WaitUntil(not Bank.IsOpen(), 200, 3000);
  end;

  // Reset position flag so script walks to altar again
  Bot.HasReachedStartTile := False;

  // Resume antiban tasks
  for i := 0 to High(Antiban.Tasks) do
    Antiban.Tasks[i].Countdown.Resume();

  WriteDebug('BirdHouseRunner.OnComplete | Birdhouse run complete, resuming reanimation');
end;

// -----------------------------------------------------------------------------
// Teleport Functions
// -----------------------------------------------------------------------------

function TReanimationBot.TeleportToCraftingGuild(): Boolean;
var
  attempts: Int32;
begin
  // Check if we are already there first
  if IsInCraftingGuild() then
  begin
    WriteDebug('TeleportToCraftingGuild | Already in Crafting Guild, skipping teleport');
    Exit(True);
  end;

  WriteDebug('TeleportToCraftingGuild | Attempting teleport...');

  for attempts := 1 to 5 do
  begin
    // Try inventory first, then equipment
    if Inventory.ClickItem('Crafting cape(t)', 'Teleport') or
       Inventory.ClickItem('Crafting cape', 'Teleport') or
       Equipment.ClickItem('Crafting cape(t)', 'Teleport') or
       Equipment.ClickItem('Crafting cape', 'Teleport') then
    begin
      if WaitUntil(IsInCraftingGuild(), 200, 8000) then
      begin
        WriteDebug('TeleportToCraftingGuild | Successfully teleported');
        Wait(1000, 1500);
        Exit(True);
      end;
    end;

    WriteDebug('TeleportToCraftingGuild | Attempt ' + ToStr(attempts) + ' failed');
    Wait(1000, 2000);
  end;

  WriteDebug('TeleportToCraftingGuild | Failed after 5 attempts');
  Result := False;
end;

(**
 * CheckRequiredSpells
 *
 * Verifies that Arceuus Library Teleport and the selected Reanimation spell
 * are available in the spellbook.
 *
 * @return True if all required spells can be activated
 *)
function TReanimationBot.CheckRequiredSpells(): Boolean;
begin
  WriteDebug('CheckRequiredSpells | Verifying required spells...');

  if not Magic.Open() then
  begin
    WriteDebug('CheckRequiredSpells | Failed to open Magic tab');
    Exit(False);
  end;

  // Set high tolerance for Arceuus spells to avoid false positives with similar icons
  SpellFinder.SimTolerance := 0.96;

  // Check Arceuus Library Teleport
  if not Magic.CanActivate(ERSSpell.ARCEUUS_LIBRARY_TELEPORT) then
  begin
    WriteDebug('CheckRequiredSpells | Arceuus Library Teleport cannot be activated (missing runes/level?)');
    Exit(False);
  end;

  // Check Reanimation Spell
  if not Magic.CanActivate(Self.ReanimationSpell) then
  begin
    WriteDebug('CheckRequiredSpells | Reanimation spell cannot be activated: ' + ToStr(Self.ReanimationSpell));
    Exit(False);
  end;

  WriteDebug('CheckRequiredSpells | Required spells are available');
  Result := True;
end;

(**
 * TeleportToArceuus
 *
 * Teleports to the Arceuus Library using the spellbook.
 * Retries up to 5 times.
 *
 * @return True if successfully reached the library
 *)
function TReanimationBot.TeleportToArceuus(): Boolean;
var
  attempts: Int32;
begin
  WriteDebug('TeleportToArceuus | Casting Arceuus Library Teleport...');

  for attempts := 1 to 5 do
  begin
    if Self.SafeCastSpell(ERSSpell.ARCEUUS_LIBRARY_TELEPORT, ['Arceuus Library', 'Library Teleport']) then
    begin
      if WaitUntil(IsAtArceuusLibrary(), 200, 8000) then
      begin
        WriteDebug('TeleportToArceuus | Successfully teleported to library');
        Wait(1000, 1500);
        Exit(True);
      end;
    end;

    WriteDebug('TeleportToArceuus | Attempt ' + ToStr(attempts) + ' failed');
    Wait(1000, 2000);
  end;

  WriteDebug('TeleportToArceuus | Failed after 5 attempts');
  Result := False;
end;

(**
 * TeleportToFeroxEnclave
 *
 * Teleports to Ferox Enclave using the equipped Ring of Dueling.
 * Handles ring crumbling checks.
 *
 * @return True if successfully reached Ferox Enclave
 *)
function TReanimationBot.TeleportToFeroxEnclave(): Boolean;
var
  attempts: Int32;
begin
  // Check if we are already there first
  if IsInFeroxEnclave() then
  begin
    WriteDebug('TeleportToFeroxEnclave | Already in Ferox Enclave, skipping teleport');

    // If we don't have a ring equipped, we need one from the bank
    if not HasRingOfDuelingEquipped() then
      Self.NeedsNewRing := True;

    Self.HasUsedPool := False;
    Exit(True);
  end;

  WriteDebug('TeleportToFeroxEnclave | Attempting teleport via Ring of Dueling...');

  for attempts := 1 to 5 do
  begin
    // Check if ring is equipped
    if not HasRingOfDuelingEquipped() then
    begin
      WriteDebug('TeleportToFeroxEnclave | No Ring of Dueling equipped, need to get one from bank');
      Self.NeedsNewRing := True;
      Exit(False);
    end;

    // Try to teleport via equipment ring of dueling
    if Equipment.ClickSlot(ERSEquipmentSlot.RING, 'Ferox Enclave') then
    begin
      if WaitUntil(IsInFeroxEnclave(), 200, 8000) then
      begin
        WriteDebug('TeleportToFeroxEnclave | Successfully teleported to Ferox Enclave');
        Wait(1000, 1500);

        // Check if ring crumbled after teleport
        if CheckRingCrumbled() then
        begin
          WriteDebug('TeleportToFeroxEnclave | Ring of Dueling crumbled to dust!');
          Self.NeedsNewRing := True;
        end;

        // Reset pool flag for new bank trip
        Self.HasUsedPool := False;
        Exit(True);
      end;
    end;

    WriteDebug('TeleportToFeroxEnclave | Attempt ' + ToStr(attempts) + ' failed');
    Wait(1000, 2000);
  end;

  WriteDebug('TeleportToFeroxEnclave | Failed after 5 attempts');
  Result := False;
end;

(**
 * TeleportToBank
 *
 * Teleports to the configured bank location (Ferox Enclave or Crafting Guild).
 *
 * @return True if teleport was successful
 *)
function TReanimationBot.TeleportToBank(): Boolean;
begin
  if Self.BankLocation = EBankLocation.BANK_FEROX_ENCLAVE then
  begin
    WriteDebug('TeleportToBank | Teleporting to Ferox Enclave...');
    Result := Self.TeleportToFeroxEnclave();
  end
  else
  begin
    WriteDebug('TeleportToBank | Teleporting to Crafting Guild...');
    Result := Self.TeleportToCraftingGuild();
  end;
end;

(**
 * DrinkFromPool
 *
 * Drinks from the Pool of Refreshment at Ferox Enclave to restore stats.
 *
 * @return True if successful
 *)
function TReanimationBot.DrinkFromPool(): Boolean;
var
  PoolObj: TRSObjectV2;
begin
  WriteDebug('DrinkFromPool | Looking for Pool of Refreshment...');

  // Setup Pool of Refreshment object
  PoolObj.SetupEx([1.2, 1.2, 5], [FEROX_POOL_TILE]);
  PoolObj.SetupUpText(['Pool', 'refreshment']);
  PoolObj.Finder.Colors += [CTS2(11183966, 11, 0.03, 0.78)];
  PoolObj.Finder.Grow := 1;
  PoolObj.Finder.Erode := 2;
  PoolObj.Walker := @Map.Walker;
  PoolObj.TrackTarget := False;

  if PoolObj.WalkClick() then
  begin
    WriteDebug('DrinkFromPool | Clicked pool, waiting for reinvigorated message...');

    // Wait for chat message: "You feel reinvigorated after drinking from the pool."
    if WaitUntil(Chat.FindMessage('reinvigorated', [CHAT_COLOR_BLACK]), 200, 15000) then
    begin
      WriteDebug('DrinkFromPool | Reinvigorated message detected, waiting for animation...');
      // Wait 2-3 seconds after the message for the animation to complete
      Wait(2000, 3000);
      Self.HasUsedPool := True;
      WriteDebug('DrinkFromPool | Finished drinking from pool');
      Result := True;
    end
    else
    begin
      // Fallback: if message not detected, still wait and assume success
      WriteDebug('DrinkFromPool | Message not detected, using fallback wait...');
      Wait(3000, 4000);
      Self.HasUsedPool := True;
      Result := True;
    end;
  end
  else
  begin
    WriteDebug('DrinkFromPool | Failed to click pool');
    Result := False;
  end;
end;

(**
 * OpenFeroxBank
 *
 * Opens the bank chest at Ferox Enclave.
 *
 * @return True if bank is opened
 *)
function TReanimationBot.OpenFeroxBank(): Boolean;
var
  BankObj: TRSObjectV2;
begin
  if Bank.IsOpen() then
  begin
    WriteDebug('OpenFeroxBank | Bank already open');
    Exit(True);
  end;

  WriteDebug('OpenFeroxBank | Looking for Ferox bank chest...');

  // Setup Ferox Enclave Bank Chest
  BankObj.SetupEx([1, 1, 2], [FEROX_BANK_TILE]);
  BankObj.SetupUpText(['Bank', 'chest']);
  BankObj.Finder.Colors += [CTS2(1458509, 7, 0.07, 0.92)];
  BankObj.Finder.Grow := 1;
  BankObj.Finder.Erode := 2;
  BankObj.Walker := @Map.Walker;
  BankObj.TrackTarget := False;

  if BankObj.WalkClick() then
  begin
    Result := WaitUntil(Bank.IsOpen(), 200, 8000);
    if Result then
      WriteDebug('OpenFeroxBank | Bank opened successfully')
    else
      WriteDebug('OpenFeroxBank | Failed to open bank');
  end
  else
    WriteDebug('OpenFeroxBank | Failed to click bank');
end;

// -----------------------------------------------------------------------------
// Banking Functions
// -----------------------------------------------------------------------------

(**
 * OpenBank
 *
 * Wrapper to open the correct bank based on configuration.
 * Handles checks for Ring of Dueling if at Ferox.
 *
 * @return True if bank is opened
 *)
function TReanimationBot.OpenBank(): Boolean;
var
  BankObj: TRSObjectV2;
begin
  // Handle based on bank location
  if Self.BankLocation = EBankLocation.BANK_FEROX_ENCLAVE then
  begin
    // Check ring before opening bank if at Ferox, BUT NOT if bank is already open
    if (not Bank.IsOpen()) and (not HasRingOfDuelingEquipped()) then
    begin
      WriteDebug('OpenBank | No Ring of Dueling equipped, setting NeedsNewRing := True');
      Self.NeedsNewRing := True;
    end;

    Result := Self.OpenFeroxBank();
    Exit;
  end;

  // Default: Crafting Guild bank
  WriteDebug('OpenBank | Looking for Crafting Guild bank chest...');

  BankObj.SetupEx([0.9, 0.9, 1], [CRAFTING_GUILD_BANK_TILE]);
  BankObj.SetupUpText(['Bank', 'chest']);
  BankObj.Finder.Colors += [CTS2(3237499, 16, 0.05, 0.78)];
  BankObj.Finder.Grow := 3;
  BankObj.Finder.Erode := 4;
  BankObj.Walker := @Map.Walker;
  BankObj.TrackTarget := False;

  if BankObj.WalkClick() then
  begin
    Result := WaitUntil(Bank.IsOpen(), 200, 8000);
    if Result then
      WriteDebug('OpenBank | Bank opened successfully')
    else
      WriteDebug('OpenBank | Failed to open bank');
  end
  else
    WriteDebug('OpenBank | Failed to click bank');
end;

(**
 * ManageInventory
 *
 * Deposits unnecessary items and ensures inventory is clean.
 * Handles Ring of Dueling replacement if needed.
 * Keeps essential runes and equipment.
 *)
procedure TReanimationBot.ManageInventory();
var
  keepItems: TRSItemArray;
  item: TRSBankItem;
begin
  if not Bank.IsOpen() then Exit;

  WriteDebug('ManageInventory | Cleaning inventory...');

  // Items we want to keep - varies by bank location
  keepItems := ['Rune pouch', 'Divine rune pouch', 'Law rune', 'Earth rune', 'Body rune', 'Nature rune', 'Soul rune', 'Blood rune'];

  if Self.BankLocation = EBankLocation.BANK_FEROX_ENCLAVE then
  begin
    // Ferox specific items to keep
  end
  else
    keepItems += ['Crafting cape', 'Crafting cape(t)'];

  // Deposit all items except keepItems using standard WaspLib method
  Bank.DepositRandomItems(keepItems);
  Wait(300, 500);

  // Reset head count since all non-essential items (including heads) were deposited
  Self.HeadCount := 0;

  // Handle bank location specific essentials
  if Self.BankLocation = EBankLocation.BANK_FEROX_ENCLAVE then
  begin
    // For Ferox Enclave, handle Ring of Dueling only when it crumbled
    // Note: Don't check HasRingOfDuelingEquipped() here - bank interface blocks equipment view
    if Self.NeedsNewRing then
    begin
      WriteDebug('ManageInventory | Ring crumbled, withdrawing and equipping new one...');
      item := TRSBankItem.Setup('Ring of dueling(8)', 1);
      if Bank.WithdrawItem(item, False) then
      begin
        Wait(600, 900);
        Bank.Close();
        WaitUntil(not Bank.IsOpen(), 200, 3000);
        Wait(300, 500);

        // Equip the ring
        if Inventory.ClickItem('Ring of dueling(8)', 'Wear') then
        begin
          WriteDebug('ManageInventory | Equipped new Ring of Dueling');
          Self.NeedsNewRing := False;
          Wait(600, 900);
        end
        else
          WriteDebug('ManageInventory | Failed to equip Ring of Dueling');

        // Re-open bank for remaining operations
        Self.OpenBank();
        WaitUntil(Bank.IsOpen(), 200, 8000);
        Wait(300, 500);
      end
      else
        WriteDebug('ManageInventory | Failed to withdraw Ring of Dueling');
    end;
  end
  else
  begin
    // For Crafting Guild, ensure crafting cape is available
    if not (Inventory.ContainsItem('Crafting cape') or Inventory.ContainsItem('Crafting cape(t)')) then
    begin
      WriteDebug('ManageInventory | Withdrawing Crafting cape...');
      if Bank.ContainsItem('Crafting cape(t)') then
        item := TRSBankItem.Setup('Crafting cape(t)', 1)
      else
        item := TRSBankItem.Setup('Crafting cape', 1);

      Bank.WithdrawItem(item, False);
      Wait(600, 900);
    end;
  end;
end;

(**
 * ShouldDrinkBankPotion
 *
 * Determines if we should drink a potion at the bank.
 * Always returns true for Dragon heads (Antifire).
 *)
function TReanimationBot.ShouldDrinkBankPotion(): Boolean;
begin
  if Self.HeadType = EHeadType.HEAD_DRAGON then
    Exit(True);
  Result := Self.UseBankPotion;
end;

(**
 * WithdrawOneDosePotion
 *
 * Attempts to withdraw a single 1-dose potion.
 * Uses search if not immediately visible.
 *
 * @param potionName The full name of the potion item
 * @return           True if successful
 *)
function TReanimationBot.WithdrawOneDosePotion(potionName: String): Boolean;
var
  item: TRSBankItem;
begin
  item := TRSBankItem.Setup(potionName, 1);
  if Bank.WithdrawItem(item, False) then
  begin
    Wait(400, 600);
    if WaitUntil(Inventory.ContainsItem(potionName), 150, 2500) then
      Exit(True);
  end;

  WriteDebug('BankPotion | Potion not visible, searching for ' + potionName);

  if Bank.Search(potionName) then
  begin
    Wait(800, 1200);
    if Bank.WithdrawItem(item, False) then
    begin
      Wait(400, 600);
      if WaitUntil(Inventory.ContainsItem(potionName), 150, 2500) then
        Exit(True);
    end;
  end;

  Result := False;
end;

(**
 * PerformBankPotionRoutine
 *
 * Handles the logic for drinking potions at the bank (boosts/antifire).
 * withdraws -> drinks -> drops vials -> reopens bank
 *
 * @return True if successful or no potions needed
 *)
function TReanimationBot.PerformBankPotionRoutine(): Boolean;
var
  potionsToDrink: TStringArray;
  potionsVariant: TVariantArray;
  i: Int32;
  potionName: String;
begin
  Result := True;

  if not Self.ShouldDrinkBankPotion() then
    Exit(True);

  // Build list of potions to drink (skip previously unavailable potions)
  if Self.UseBankPotion then
  begin
    if Self.CombatPotionUnavailable then
      WriteDebug('BankPotion | Skipping combat potion (previously unavailable)')
    else
      potionsToDrink += GetPotionItemName(Self.BankPotion);
  end;

  // Dragon heads require antifire (Extended preferred)
  if Self.HeadType = EHeadType.HEAD_DRAGON then
  begin
    if Self.AntifirePotionUnavailable then
      WriteDebug('BankPotion | Skipping antifire potion (previously unavailable)')
    else
      potionsToDrink += 'Extended antifire(1)';
  end;

  if Length(potionsToDrink) = 0 then
    Exit(True);

  WriteDebug('BankPotion | Routine started. Potions: ' + ToStr(potionsToDrink));

  if not Bank.IsOpen() then
    Exit(False);

  // Withdraw all required potions
  for i := 0 to High(potionsToDrink) do
  begin
    potionName := potionsToDrink[i];
    if not Self.WithdrawOneDosePotion(potionName) then
    begin
      WriteDebug('BankPotion | Failed to withdraw ' + potionName);

      // For dragon heads, try regular antifire if extended fails
      if (Self.HeadType = EHeadType.HEAD_DRAGON) and (potionName = 'Extended antifire(1)') then
      begin
        WriteDebug('BankPotion | Extended antifire not found, trying regular Antifire...');
        if Self.WithdrawOneDosePotion('Antifire potion(1)') then
        begin
          potionsToDrink[i] := 'Antifire potion(1)';
          WriteDebug('BankPotion | Withdrew regular Antifire potion(1)');
        end
        else
        begin
          WriteLn('WARNING: No Antifire potions found in bank!');
          WriteLn('WARNING: Shield will be used, but you will not have full immunity against Dragon fire breath!');
          Self.AntifirePotionUnavailable := True;
          WriteDebug('BankPotion | Antifire potions cached as unavailable, will not attempt again');
        end;
      end
      else if Self.UseBankPotion and (potionName = GetPotionItemName(Self.BankPotion)) then
      begin
        Self.CombatPotionUnavailable := True;
        WriteDebug('BankPotion | Combat potion cached as unavailable, will not attempt again');
      end;
    end;
  end;

  // Convert to TVariantArray for Inventory.ContainsAny
  potionsVariant := [];
  for i := 0 to High(potionsToDrink) do
    potionsVariant += potionsToDrink[i];

  // Check if we actually have anything to drink
  if not Inventory.ContainsAny(potionsVariant) then
  begin
    WriteDebug('BankPotion | No potions in inventory to drink');
    Exit(True);
  end;

  Bank.Close();
  WaitUntil(not Bank.IsOpen(), 200, 3000);
  Wait(200, 400);

  // Drink them
  for i := 0 to High(potionsToDrink) do
  begin
    potionName := potionsToDrink[i];
    if Inventory.ContainsItem(potionName) then
    begin
      if Inventory.ClickItem(potionName, 'Drink') then
      begin
        Wait(1900, 2400); // Wait for potion cooldown (3 ticks)
        WriteDebug('BankPotion | Drank ' + potionName);
      end
      else
        WriteDebug('BankPotion | Failed to drink ' + potionName);
    end;
  end;

  // Drop all vials
  while Inventory.ContainsItem('Vial') do
  begin
    Inventory.ClickItem('Vial', 'Drop');
    Wait(250, 450);
  end;
  WriteDebug('BankPotion | Dropped empty vials');

  if not Self.OpenBank() then
  begin
    WriteDebug('BankPotion | Failed to reopen bank after drinking');
    Exit(False);
  end;

  Wait(400, 600);
end;

(**
 * HandleBanking
 *
 * Main banking routine:
 * 1. Clean inventory
 * 2. Drink potions
 * 3. Withdraw heads
 *)
function TReanimationBot.HandleBanking(): Boolean;
begin
  if not Bank.IsOpen() then
    Exit(False);

  WriteDebug('HandleBanking | Bank is open, withdrawing heads...');
  Wait(600, 900);

  Self.ManageInventory();

  // Optional one-dose potion boost each bank trip before grabbing heads
  if not Self.PerformBankPotionRoutine() then
  begin
    WriteDebug('HandleBanking | Potion routine failed, continuing to heads');
    if not Bank.IsOpen() then
      Self.OpenBank();
  end;

  // Try to withdraw directly first (fast path)
  if Bank.WithdrawItem(Self.HeadItem, False) then
  begin
    Wait(600, 900);
    if WaitUntil(Inventory.ContainsItem(Self.HeadItem), 200, 3000) then
    begin
      Self.HeadCount := Inventory.CountItem(Self.HeadItem);
      WriteDebug('HandleBanking | Successfully withdrew ' + ToStr(Self.HeadCount) + ' heads');
      Self.NeedsEmergencyHeal := False;
      Exit(True);
    end;
  end;

  WriteDebug('HandleBanking | Failed to find/withdraw heads in current view. Searching...');

  // Use search to find the item (handles tabs and scrolling)
  if Bank.Search(GetHeadItemName(Self.HeadType)) then
  begin
    Wait(1000, 1500); // Wait for search filter

    if Bank.WithdrawItem(Self.HeadItem, False) then
    begin
      Wait(600, 900);
      if WaitUntil(Inventory.ContainsItem(Self.HeadItem), 200, 3000) then
      begin
        Self.HeadCount := Inventory.CountItem(Self.HeadItem);
        WriteDebug('HandleBanking | Successfully withdrew ' + ToStr(Self.HeadCount) + ' heads after search');
        Self.NeedsEmergencyHeal := False;
        Exit(True);
      end;
    end;
  end;

  WriteDebug('HandleBanking | No heads found in bank even after search!');
  Bank.Close();
  Wait(500, 800);
  Self.Report();
  TerminateScript('Out of ensouled heads - script finished');
end;

// -----------------------------------------------------------------------------
// Walking Functions
// -----------------------------------------------------------------------------

(**
 * HandleQuickPrayers
 *
 * Enables or disables quick prayers.
 * Automatically disables the feature if prayers aren't configured.
 *
 * @param Enable True to turn on, False to turn off
 *)
procedure TReanimationBot.HandleQuickPrayers(Enable: Boolean);
begin
  if not Self.UseQuickPrayers then Exit;

  if Enable then
  begin
    if Minimap.GetLevel(ERSMinimapOrb.PRAYER) <= 0 then
    begin
      WriteDebug('HandleQuickPrayers | Prayer points depleted, skipping activation');
      Exit;
    end;

    if Minimap.IsPrayerEnabled() then
    begin
      WriteDebug('HandleQuickPrayers | Quick prayers already active');
      Exit;
    end;

    WriteDebug('HandleQuickPrayers | Enabling Quick Prayers...');
    Minimap.EnablePrayer(); // Ignore result, check chat/state directly

    Wait(600, 900); // Give time for message to appear

    // Check for error message - relax string matching
    if Chat.FindMessage('selected any quick prayers', [CHAT_COLOR_BLACK]) then
    begin
      WriteDebug('HandleQuickPrayers | Error: No quick prayers configured! Disabling feature.');
      Self.UseQuickPrayers := False;
      Exit;
    end;

    // Verify if actually enabled
    if not Minimap.IsPrayerEnabled() then
    begin
      WriteDebug('HandleQuickPrayers | Failed to enable quick prayers (not configured?). Disabling feature.');
      Self.UseQuickPrayers := False;
    end;
  end
  else
  begin
    if not Minimap.IsPrayerEnabled() then Exit;

    WriteDebug('HandleQuickPrayers | Disabling Quick Prayers...');
    Minimap.DisablePrayer();
  end;
end;

(**
 * WalkToAltar
 *
 * Walks to the precise altar tile for reanimation.
 * Includes a fallback to direct minimap clicking if WebWalk fails repeatedly.
 *
 * @return True if reached the tile (within 1 tile tolerance)
 *)
function TReanimationBot.WalkToAltar(): Boolean;
var
  startPos: TPoint;
  mmPoint: TPoint;
  targetAngle: Double;
begin
  startPos := Map.Position();
  WriteDebug('WalkToAltar | Walking from ' + ToStr(startPos) + ' to altar tile ' + ToStr(ALTAR_START_TILE));

  // Tier 2 Recovery: After 6 failures, use direct minimap click
  if Self.WalkFailureCount >= 6 then
  begin
    WriteDebug('WalkToAltar | Tier 2 recovery: Using direct minimap click...');
    mmPoint := Map.Map2MM(ALTAR_START_TILE);
    if Minimap.IsPointOn(mmPoint) then
    begin
      Mouse.Click(mmPoint, MOUSE_LEFT);
      WaitUntil(not Minimap.IsPlayerMoving(), 200, 5000);
      Wait(300, 500);
      WriteDebug('WalkToAltar | Minimap click completed, now at ' + ToStr(Map.Position()));
    end
    else
      WriteDebug('WalkToAltar | Target not visible on minimap');



    Self.WalkFailureCount := 0;  // Reset after Tier 2 recovery
  end
  // Tier 1 Recovery: After 3 failures, rotate camera
  else if Self.WalkFailureCount >= 3 then
  begin
    WriteDebug('WalkToAltar | Tier 1 recovery: Rotating camera...');
    targetAngle := Random(0, 360);
    Minimap.SetCompassAngle(targetAngle);
    Wait(500, 1000);
    WriteDebug('WalkToAltar | Camera rotated to ' + ToStr(Round(targetAngle)) + ' degrees');
  end;

  // Normal walk attempt
  if Map.Walker.WebWalk(ALTAR_START_TILE, 0, 0.2) then
    WriteDebug('WalkToAltar | WebWalk completed');

  // Verify distance and correct if necessary
  if Map.Position().DistanceTo(ALTAR_START_TILE) > 1 then
  begin
    WriteDebug('WalkToAltar | Not at exact tile (Dist: ' + ToStr(Map.Position().DistanceTo(ALTAR_START_TILE)) + '), correcting...');

    // Force walk to exact tile
    if Map.Walker.WalkBlind(ALTAR_START_TILE, 0) then
      WaitUntil(not Minimap.IsPlayerMoving(), 200, 5000);
  end;

  // Strict success check (within 1 tile)
  if Map.Position().DistanceTo(ALTAR_START_TILE) <= 1 then
  begin
    WriteDebug('WalkToAltar | Arrived at altar tile');
    Self.CurrentTile := Map.Position();
    Self.WalkFailureCount := 0;  // Reset on success
    Result := True;
  end
  else
  begin
    Self.WalkFailureCount := Self.WalkFailureCount + 1;
    WriteDebug('WalkToAltar | Failed to reach exact altar tile. Current: ' + ToStr(Map.Position()) + ' (Attempt ' + ToStr(Self.WalkFailureCount) + '/6)');
    Result := False;
  end;
end;

(**
 * CheckNoRoomMessage
 *
 * Checks chat for "no room to re-animate" message.
 * Updates the internal counter to detect *new* messages.
 *
 * @return True if a NEW message was detected
 *)
function TReanimationBot.CheckNoRoomMessage(): Boolean;
var
  currentCount: Int32;
  i: Int32;
begin
  currentCount := 0;
  for i := 0 to 7 do
    if NO_ROOM_MESSAGE in Chat.GetMessage(i, [CHAT_COLOR_BLACK]) then
      Inc(currentCount);

  Result := currentCount > Self.LastNoRoomCount;

  if Result then
    WriteDebug('CheckNoRoomMessage | New error message detected! Count increased from ' + ToStr(Self.LastNoRoomCount) + ' to ' + ToStr(currentCount));

  // Always update to current count so next check is against current state
  Self.LastNoRoomCount := currentCount;
end;

(**
 * ResetPosition
 *
 * Resets player position to the defined reset tile.
 * Used when "no room" error occurs or position drifts too far.
 *
 * @return True if reset was successful
 *)
function TReanimationBot.ResetPosition(): Boolean;
begin
  WriteDebug('ResetPosition | Checking for combat before resetting...');
  Self.WaitCombatEnd();

  if Self.NeedsManualReset then
  begin
    WriteDebug('ResetPosition | Performing manual reset: walking to reset tile ' + ToStr(ALTAR_RESET_TILE));
    if Map.Walker.WalkBlind(ALTAR_RESET_TILE, 0) then
    begin
      WaitUntil(not Minimap.IsPlayerMoving(), 200, 5000);
      Wait(1000, 2000); // Wait at reset tile for area to clear
      Self.NeedsManualReset := False; // Clear flag
      WriteDebug('ResetPosition | Reached reset tile, now moving back to start tile');
    end
    else
      WriteDebug('ResetPosition | Failed to walk to reset tile');
  end;

  WriteDebug('ResetPosition | Moving back to start tile ' + ToStr(ALTAR_START_TILE));

  if Map.Walker.WalkBlind(ALTAR_START_TILE, 4) then
  begin
    WaitUntil(not Minimap.IsPlayerMoving(), 200, 5000);
    Self.CurrentTile := Map.Position();
    WriteDebug('ResetPosition | Now at ' + ToStr(Self.CurrentTile));
    Result := True;
  end
  else
    WriteDebug('ResetPosition | Failed to walk to start tile');
end;

(**
 * NeedsPositionReset
 *
 * Checks if the player has drifted too far West (past reset tile).
 *
 * @return True if position reset is needed
 *)
function TReanimationBot.NeedsPositionReset(): Boolean;
var
  pos: TPoint;
begin
  pos := Map.Position();
  // Reset if we've moved past the reset tile (X <= 2716)
  Result := pos.X <= ALTAR_RESET_TILE.X;
  if Result then
    WriteDebug('NeedsPositionReset | Position ' + ToStr(pos) + ' past reset threshold');
end;

// -----------------------------------------------------------------------------
// Combat Functions
// -----------------------------------------------------------------------------

(**
 * CastReanimation
 *
 * Casts the reanimation spell on the ensouled head in inventory.
 * Handles "no room" errors immediately after casting.
 *
 * @return True if spell was cast and head consumed (animation started)
 *)
function TReanimationBot.CastReanimation(): Boolean;
begin
  WriteDebug('CastReanimation | Casting ' + ToStr(Self.ReanimationSpell) + ' on ' + ToStr(Self.HeadItem));

  if Self.SafeCastSpell(Self.ReanimationSpell, ['Reanimate', 'Reanimation']) then
  begin
    if WaitUntil(Inventory.IsOpen(), 100, 3000) then
    begin
      Wait(200, 400); // Wait for inventory to settle
      if Inventory.ClickItem(Self.HeadItem, '>') then
      begin
        // Brief wait and check for "no room" message
        Wait(400, 600);
        if Self.CheckNoRoomMessage() then
        begin
          WriteDebug('CastReanimation | Detected "no room" message! Setting manual reset flag.');
          Self.NeedsManualReset := True;
          Exit(False);
        end;

        Self.SpawnTile := Map.Position();
        Self.HeadsUsed += 1;
        Self.TotalActions += 1;
        Self.HeadCount -= 1;
        Self.HeadPendingXP := True;
        Wait(600, 800);
        WriteDebug('CastReanimation | Spell cast, spawn tile: ' + ToStr(Self.SpawnTile) + ', heads remaining: ' + ToStr(Self.HeadCount));
        Result := True;
      end
      else
        WriteDebug('CastReanimation | Failed to click head');
    end
    else
      WriteDebug('CastReanimation | Inventory did not open after spell');
  end
  else
    WriteDebug('CastReanimation | Failed to cast spell');
end;

(**
 * WaitForMonsterSpawn
 *
 * Waits for the reanimated monster NPC to appear near the spawn tile.
 * Checks for "no room" messages during the wait.
 *
 * @return True if monster appeared
 *)
function TReanimationBot.WaitForMonsterSpawn(): Boolean;
var
  Timeout: TCountdown;
  MMBox: TBox;
  StartDotCount: Int32;
  MMPoint, MSP: TPoint;
begin
  WriteDebug('WaitForMonsterSpawn | Waiting for monster near ' + ToStr(Self.SpawnTile));

  // Quick check for "no room" message before waiting
  if Self.CheckNoRoomMessage() then
  begin
    WriteDebug('WaitForMonsterSpawn | Detected "no room" message immediately! Setting manual reset flag.');
    Self.NeedsManualReset := True;
    Exit(False);
  end;

  // Pre-position mouse near spawn area for faster attack
  MSP := Minimap.PointToMS(Map.Map2MM(Self.SpawnTile));
  if MainScreen.Bounds.Contains(MSP) then
  begin
    Mouse.Move(SRL.RandomPoint(Box(MSP, 40, 40)));
    WriteDebug('WaitForMonsterSpawn | Pre-positioned mouse at spawn area');
  end;

  // Monster takes ~6.7s to appear. We wait 4s first to reduce unnecessary checking.
  Wait(4000);

  MMPoint := Map.Map2MM(Self.SpawnTile);
  // Using 20x20 box as requested, enough for large monsters
  MMBox := Box(MMPoint, 20, 20);
  StartDotCount := Length(Minimap.GetDots(ERSMinimapDot.NPC, MMBox));

  // Reduced timeout since we already waited 4s
  Timeout.Init(8000);
  while not Timeout.IsFinished() do
  begin
    MMPoint := Map.Map2MM(Self.SpawnTile);
    MMBox := Box(MMPoint, 20, 20);

    if Length(Minimap.GetDots(ERSMinimapDot.NPC, MMBox)) > StartDotCount then
    begin
      WriteDebug('WaitForMonsterSpawn | Monster detected!');
      Self.MonsterSpawned := True;
      Self.AttackAttempts := 0;
      Wait(200, 400);
      Exit(True);
    end;

    // Check for "no room" message
    if Self.CheckNoRoomMessage() then
    begin
      WriteDebug('WaitForMonsterSpawn | Detected "no room" message! Setting manual reset flag.');
      Self.NeedsManualReset := True;
      Exit(False);
    end;

    Wait(200);
  end;

  WriteDebug('WaitForMonsterSpawn | Timeout - No monster appeared in spawn radius');
  Result := False;
end;

(**
 * AttackMonster
 *
 * Finds and attacks the reanimated monster.
 * Uses multiple strategies:
 * 1. Spawn tile check (fastest)
 * 2. NPC Dot proximity + Color check (robust)
 * 3. NPC Dot blind click (fallback)
 *
 * @return True if attack initiated
 *)
function TReanimationBot.AttackMonster(): Boolean;
var
  ClickBox, SearchBox: TBox;
  Dots, FilteredDots: TPointArray;
  P, MSP, MMSpawn: TPoint;
  i: Int32;
  isLarge: Boolean;
  MonsterColor: TCTS2Color;
  TPA: TPointArray;
  ATPA: T2DPointArray;
begin
  isLarge := IsLargeMonster(Self.HeadType);
  MonsterColor := CTS2(10633316, 18, 0.27, 0.84); // Purple for Reanimated Monster

  if isLarge then
    WriteDebug('AttackMonster | Searching for large reanimated monster...')
  else
    WriteDebug('AttackMonster | Searching for small reanimated monster...');

  // 1. SMALL MONSTERS: Try exact spawn tile first (previous robust method)
  if not isLarge then
  begin
    ClickBox := Map.GetTileMS(Self.SpawnTile, 4).Bounds;
    if MainScreen.IsVisible(ClickBox.Middle) then
    begin
      // Color pre-check for spawn tile method (optional info)
      if SRL.FindColors(TPA, MonsterColor, ClickBox) then
        WriteDebug('AttackMonster | Detected monster color at spawn tile');

      Mouse.Move(ClickBox);
      // Using original robust timeout for small monsters
      if WaitUntil(MainScreen.IsUpText('Reanimated'), 50, 1500) then
      begin
        Mouse.Click(MOUSE_LEFT);
        if MainScreen.DidRedClick() then
        begin
          WriteDebug('AttackMonster | Successfully attacked small monster via spawn tile');
          Self.IsInCombat := True;
          Exit(True);
        end;
      end;
    end;
  end;

  // 2. NPC DOTS LOGIC
  MMSpawn := Map.Map2MM(Self.SpawnTile);
  Dots := Minimap.GetDots(ERSMinimapDot.NPC);

  // Filter dots within 20 pixels radius of spawn point on minimap
  FilteredDots := Dots.FilterDist(0, 20, MMSpawn.X, MMSpawn.Y);

  if Length(FilteredDots) = 0 then
  begin
    WriteDebug('AttackMonster | No NPC dots found near spawn area');
    Exit(False);
  end;

  // Sort by proximity to spawn point (not player)
  FilteredDots.SortFrom(MMSpawn);
  WriteDebug('AttackMonster | Checking ' + ToStr(Length(FilteredDots)) + ' dots near spawn');

  // PASS 1: Color Priority Check
  // Iterate all dots and check if any match the specific purple color on mainscreen
  for i := 0 to High(FilteredDots) do
  begin
    P := FilteredDots[i];
    MSP := Minimap.PointToMS(P);

    // Define search box around the projected point
    // Increase size for large monsters or slight projection errors
    SearchBox := Box(MSP, 60, 60);
    SearchBox.LimitTo(MainScreen.Bounds);

    if SRL.FindColors(TPA, MonsterColor, SearchBox) then
    begin
      // Filter out small noise
      ATPA := TPA.Cluster(5);
      ATPA.FilterSize(20, 10000);
      ATPA.SortByMiddle(MSP);

      if Length(ATPA) > 0 then
      begin
        WriteDebug('AttackMonster | Found monster color match near dot ' + ToStr(i));
        Mouse.Move(ATPA[0].Bounds); // Move to actual color location

        if WaitUntil(MainScreen.IsUpText('Reanimated'), 50, 1200) then
        begin
          Mouse.Click(MOUSE_LEFT);
          if MainScreen.DidRedClick() then
          begin
            WriteDebug('AttackMonster | Attacked reanimated monster via Color Priority');
            Self.IsInCombat := True;
            Exit(True);
          end;
        end;
      end;
    end;
  end;

  // PASS 2: Fallback to Blind Click (Old Logic)
  // If color check failed for all dots, try the old method (check UpText at MSP)
  WriteDebug('AttackMonster | Color check failed, falling back to UpText check');

  for i := 0 to High(FilteredDots) do
  begin
    P := FilteredDots[i];
    MSP := Minimap.PointToMS(P);

    // Try base point
    if MainScreen.Bounds.Contains(MSP) then
    begin
      Mouse.Move(MSP);
      if WaitUntil(MainScreen.IsUpText('Reanimated'), 50, 1200) then
      begin
        Mouse.Click(MOUSE_LEFT);
        if MainScreen.DidRedClick() then
        begin
          WriteDebug('AttackMonster | Attacked reanimated monster via NPC dot (fallback)');
          Self.IsInCombat := True;
          Exit(True);
        end;
      end;
    end;

    // Try offset point ONLY for large monsters (Dragons/Gaints etc)
    if isLarge then
    begin
      MSP.Y -= 20;
      if MainScreen.Bounds.Contains(MSP) then
      begin
        Mouse.Move(MSP);
        if WaitUntil(MainScreen.IsUpText('Reanimated'), 50, 1000) then
        begin
          Mouse.Click(MOUSE_LEFT);
          if MainScreen.DidRedClick() then
          begin
            WriteDebug('AttackMonster | Attacked reanimated monster via NPC dot (offset fallback)');
            Self.IsInCombat := True;
            Exit(True);
          end;
        end;
      end;
    end;
  end;

  WriteDebug('AttackMonster | Failed to find "Reanimated" uptext on nearby NPCs');
  Result := False;
end;

(**
 * IsActuallyInCombat
 *
 * Verifies combat state using MainScreen red ring or XP drops.
 * Useful for double-checking if an attack was successful.
 *
 * @return True if combat detected
 *)
function TReanimationBot.IsActuallyInCombat(): Boolean;
var
  startXP, currentXP: Int32;
begin
  // First check MainScreen for quick detection
  if MainScreen.InCombat() then
  begin
    WriteDebug('IsActuallyInCombat | Detected via MainScreen.InCombat()');
    Exit(True);
  end;

  // Check for XP gain (more reliable for hidden monsters)
  startXP := XPBar.Read();
  Wait(800, 1200); // Reduced from 2-3s to ~1s for faster response
  currentXP := XPBar.Read();

  Result := currentXP > startXP;

  if Result then
    WriteDebug('IsActuallyInCombat | Detected combat via XP gain: ' + ToStr(currentXP - startXP));
end;

(**
 * FindPrayerXPDrop
 *
 * Scans the XP drop area for the Prayer XP icon using DTM.
 * This is the primary confirmation of a kill.
 *
 * @return True if Prayer XP drop found
 *)
function TReanimationBot.FindPrayerXPDrop(): Boolean;
var
  x, y: Int32;
  dtm: Int32;
  searchArea: TBox;
  clientBounds: TBox;
begin
  // Get client bounds and define search area where XP drops appear (right side, near top)
  clientBounds := GetClientBounds();
  searchArea := [clientBounds.X2 - 380, clientBounds.Y1 + 30, clientBounds.X2 - 250, clientBounds.Y1 + 170];

  // Load DTM from string
  dtm := DTMFromString(PRAYER_XP_DTM);

  try
    // Search for prayer XP drop DTM in the XP drop area
    Result := FindDTM(dtm, x, y, searchArea);

    if Result then
    begin
      WriteDebug('FindPrayerXPDrop | Prayer XP drop DTM detected at [' + ToStr(x) + ', ' + ToStr(y) + ']');
      WL.Activity.Restart();
    end;
  finally
    FreeDTM(dtm);
  end;
end;

(**
 * WaitCombatEnd
 *
 * Blocks execution while combat is active.
 * Handles special attacks, XP monitoring, and timeout checks.
 *
 * @return True if combat finished successfully (monster killed)
 *)
function TReanimationBot.WaitCombatEnd(): Boolean;
var
  Timeout: TCountdown;
  LastXP, CurrentXP: Int32;
  NoActivityTimer: TCountdown;
  prayerXPDetected: Boolean;
  SpecTimer: TStopwatch;
begin
  WriteDebug('WaitCombatEnd | Waiting for combat to finish...');

  Timeout.Init(120000); // 2 minute max for combat
  NoActivityTimer.Init(15000); // 15 seconds without activity = done
  SpecTimer.Start();
  LastXP := XPBar.Read();

  while not Timeout.IsFinished() do
  begin
    
    // Check for prayer XP drop using DTM (indicates monster killed)
    prayerXPDetected := Self.FindPrayerXPDrop();

    // If prayer XP drop detected, exit immediately - monster is killed!
    if prayerXPDetected then
    begin
      WriteDebug('WaitCombatEnd | Prayer XP drop DTM detected, monster killed!');
      Wait(200, 400); // Brief wait for XP to register
      if Self.HeadPendingXP then
        Self.MonstersKilled += 1;
      Self.HeadPendingXP := False;
      Self.IsInCombat := False;
      Self.MonsterSpawned := False;
      Self.CurrentTile := Map.Position();
      WL.Activity.Restart();
      Exit(True);
    end;

    // Attempt special attack periodically (Every 7s, 70% chance)
    if SpecTimer.ElapsedTime() > 7000 then
    begin
      Self.AttemptSpec();
      SpecTimer.Reset();
    end;

    // Check for XP gain (indicates combat activity)
    CurrentXP := XPBar.Read();
    if CurrentXP > LastXP then
    begin
      LastXP := CurrentXP;
      NoActivityTimer.Restart(15000);
      WL.Activity.Restart();
    end;

    // Check if still in combat
    if not MainScreen.InCombat() then
    begin
      if SRL.IsAnimating(MainScreen.GetPlayerBox(), 450, 350, 3) then
      begin
        Wait(300, 500);
        Continue;
      end;

      WriteDebug('WaitCombatEnd | Combat ring missing, verifying...');

      if WaitUntil(MainScreen.InCombat(), 100, 4000) then
      begin
        WriteDebug('WaitCombatEnd | Combat ring reappeared!');
        Continue;
      end;

      if SRL.IsAnimating(MainScreen.GetPlayerBox(), 450, 350, 3) then
      begin
        WriteDebug('WaitCombatEnd | Player still animating, ignoring combat ring');
        Continue;
      end;

      WriteDebug('WaitCombatEnd | Combat finished without prayer XP drop');
      Self.HeadPendingXP := False;
      Self.IsInCombat := False;
      Self.MonsterSpawned := False;
      Self.CurrentTile := Map.Position();
      Exit(True);
    end;

    // No activity timeout
    if NoActivityTimer.IsFinished() then
    begin
      WriteDebug('WaitCombatEnd | No activity for 15 seconds, assuming done');
      Self.HeadPendingXP := False;
      Self.IsInCombat := False;
      Self.MonsterSpawned := False;
      Exit(True);
    end;

    Wait(100, 200);
  end;

  WriteDebug('WaitCombatEnd | Combat timeout reached');
  Self.HeadPendingXP := False;
  Self.IsInCombat := False;
  Self.MonsterSpawned := False;
  Result := False;
end;

(**
 * CorrectHeadCount
 *
 * Syncs the internal head count with actual inventory count.
 * Fixes drifts caused by misclicks or lag.
 *
 * @return True if count was corrected
 *)
function TReanimationBot.CorrectHeadCount(): Boolean;
var
  actualCount: Int32;
begin
  if not Inventory.ContainsItem(Self.HeadItem) then
    Exit(False);

  actualCount := Inventory.CountItem(Self.HeadItem);
  if actualCount > 0 then
  begin
    // If we have more heads than we thought (e.g. 0), we probably missed a cast failure
    // Correct the HeadsUsed stat by subtracting the difference
    if actualCount > Self.HeadCount then
    begin
      Self.HeadsUsed -= (actualCount - Self.HeadCount);
      Self.TotalActions -= (actualCount - Self.HeadCount);
    end;

    Self.HeadCount := actualCount;
    WriteDebug('CorrectHeadCount | Correction: Found ' + ToStr(Self.HeadCount) + ' heads remaining. Adjusted HeadsUsed.');
    Result := True;
  end;
end;

// -----------------------------------------------------------------------------
// State Machine
// -----------------------------------------------------------------------------

(**
 * GetState
 *
 * Determines the next action based on player state.
 * Priority: Login > Health > Arceuus Logic > Combat > Banking
 *
 * @return The next state to execute
 *)
function TReanimationBot.GetState(): EReanimationState;
var
  pos: TPoint;
begin
  if not RSClient.IsLoggedIn() then
    Exit(EReanimationState.HANDLE_LOGIN);

  if Minimap.GetHPPercent() < MIN_HEALTH_PERCENT then
  begin
    if Self.BankLocation = EBankLocation.BANK_FEROX_ENCLAVE then
    begin
      WriteDebug('Health Check | HP is below ' + ToStr(MIN_HEALTH_PERCENT) + '% (' + ToStr(Minimap.GetHPPercent()) + '%). Emergency healing at Ferox.');
      Self.NeedsEmergencyHeal := True;
    end
    else
    begin
      WriteDebug('Health Check | HP is below ' + ToStr(MIN_HEALTH_PERCENT) + '% (' + ToStr(Minimap.GetHPPercent()) + '%). Terminating script.');
      TerminateScript('Health Safety Triggered (HP < ' + ToStr(MIN_HEALTH_PERCENT) + '%)');
    end;
  end;

  // Emergency heal flow: teleport to Ferox, use pool, bank, then resume
  if Self.NeedsEmergencyHeal then
  begin
    if not IsInFeroxEnclave() then
      Exit(EReanimationState.EMERGENCY_HEAL);

    if not Self.HasUsedPool then
      Exit(EReanimationState.USE_POOL);

    // At Ferox with pool used - bank normally, then reset flag after banking
    if Bank.IsOpen() then
      Exit(EReanimationState.HANDLE_BANK);

    Exit(EReanimationState.OPEN_BANK);
  end;

  // Check for script end conditions
  if WL.Activity.IsFinished() then
    Exit(EReanimationState.END_SCRIPT);

  pos := Map.Position();

  // If we have heads and are in Arceuus, prioritize movement/reset over combat wait
  if (Self.HeadCount > 0) and IsInArceuusArea() then
  begin
    if Self.NeedsManualReset or Self.NeedsPositionReset() then
      Exit(EReanimationState.RESET_POSITION);

    if not Self.HasReachedStartTile then
    begin
      if Map.Position().DistanceTo(ALTAR_START_TILE) <= 1 then
      begin
        Self.HasReachedStartTile := True;
        // If we just arrived, we shouldn't be waiting for combat from previous location
        Self.IsInCombat := False;
      end
      else
        Exit(EReanimationState.WALK_TO_ALTAR);
    end;
  end;

  // If in combat, wait for it to end
  if Self.IsInCombat then
    Exit(EReanimationState.WAIT_COMBAT_END);

  // If monster spawned but not attacked yet
  if Self.MonsterSpawned then
    Exit(EReanimationState.ATTACK_MONSTER);

  // Bank handling
  if Bank.IsOpen() then
  begin
    if Self.HeadCount > 0 then
      Exit(EReanimationState.CLOSE_BANK);
    Exit(EReanimationState.HANDLE_BANK);
  end;

  // If we have heads in inventory
  if Self.HeadCount > 0 then
  begin
    // If in Arceuus area
    if IsInArceuusArea() then
    begin
      // Logic for Reset/Walk moved up to prioritize over combat wait.
      // If we are here, we are at start tile and not in combat (or willing to cast).
      Exit(EReanimationState.CAST_REANIMATE);
    end
    else
    begin
      // Need to teleport to Arceuus
      Exit(EReanimationState.TELEPORT_TO_ARCEUUS);
    end;
  end
  else
  begin
    // Double check inventory count to prevent premature banking due to count drift
    if Self.CorrectHeadCount() then
      Exit(Self.GetState());

    WriteDebug('GetState | No heads remaining (HeadCount: ' + ToStr(Self.HeadCount) + '), returning to bank');
    // No heads - reset start tile flag and bank
    Self.HasReachedStartTile := False;
    Self.IsInCombat := False;

    // Handle based on bank location
    if Self.BankLocation = EBankLocation.BANK_FEROX_ENCLAVE then
    begin
      // Ferox Enclave banking flow
      if IsInFeroxEnclave() then
      begin
        // Check if we need to use the pool first
        if not Self.HasUsedPool then
          Exit(EReanimationState.USE_POOL);
        Exit(EReanimationState.OPEN_BANK);
      end
      else
        Exit(EReanimationState.TELEPORT_TO_BANK);
    end
    else
    begin
      // Crafting Guild banking flow
      if IsInCraftingGuild() then
        Exit(EReanimationState.OPEN_BANK)
      else
        Exit(EReanimationState.TELEPORT_TO_BANK);
    end;
  end;

  // Default antiban
  Exit(EReanimationState.DO_ANTIBAN);
end;

// -----------------------------------------------------------------------------
// Initialization
// -----------------------------------------------------------------------------

(**
 * Init
 *
 * Sets up script variables, map chunks, and verifies equipment.
 *
 * @param maxActions Max actions before stopping (unused)
 * @param maxTime    Max runtime in ms
 *)
procedure TReanimationBot.Init(maxActions: UInt32; maxTime: UInt64); override;
begin
  inherited;

  // Disable native WaspLib reports in favor of Orka custom report
  WLSettings.Put('reports', False);

  if Self.BankLocation = EBankLocation.BANK_FEROX_ENCLAVE then
  begin
    Map.SetupChunks([
      Chunk([24, 61, 27, 59], 0),  // Arceuus Library / Altar
      Chunk([48, 57, 50, 55], 0)   // Ferox Enclave
    ]);
  end
  else
  begin
    Map.SetupChunks([
      Chunk([24, 61, 27, 59], 0),  // Arceuus Library / Altar
      Chunk([44, 52, 46, 50], 0)   // Crafting Guild
    ]);
  end;

  if Self.HeadType = EHeadType.HEAD_DRAGON then
  begin
    WriteDebug('Init | Checking for dragonfire protection...');
    if not (Equipment.ContainsItem('Anti-dragon shield') or Equipment.ContainsItem('Dragonfire shield')) then
    begin
      WriteLn('ERROR: Dragon reanimation requires "Anti-dragon shield" or "Dragonfire shield" equipped!');
      TerminateScript('Missing Anti-dragon shield');
    end;
    WriteDebug('Init | Dragonfire protection verified');
  end;

  Self.HeadItem := GetHeadItemName(Self.HeadType);
  Self.ReanimationSpell := GetReanimationSpell(Self.HeadType);
  Self.VerifiedSpells := False;

  Self.HeadsUsed := 0;
  Self.MonstersKilled := 0;
  Self.HeadPendingXP := False;
  Self.IsInCombat := False;
  Self.MonsterSpawned := False;
  Self.HasReachedStartTile := False;
  Self.AttackAttempts := 0;
  Self.WalkFailureCount := 0;

  // Ferox Enclave state
  Self.HasUsedPool := False;
  if Self.BankLocation = EBankLocation.BANK_FEROX_ENCLAVE then
    Self.NeedsNewRing := not HasRingOfDuelingEquipped()
  else
    Self.NeedsNewRing := False;
  Self.NeedsManualReset := False;
  Self.CheckNoRoomMessage(); // Initialize chat message count

  // Initialize head count - check inventory at startup (one-time only)
  if Inventory.ContainsItem(Self.HeadItem) then
  begin
    Self.HeadCount := Inventory.CountItem(Self.HeadItem);
    WriteDebug('Init | Starting with ' + ToStr(Self.HeadCount) + ' heads in inventory');
  end
  else
  begin
    Self.HeadCount := 0;
    WriteDebug('Init | Starting with no heads in inventory');
  end;

  Self.TotalBreakTime := 0;
  Self.LastBreakStartTime := 0;
  Self.LastBreakEndTime := 0;

  Self.CurrentTile := Map.Position();

  Self.ReportTimer.Start();

  // Initialize BirdHouseRunner if enabled
  if Self.DoBHRuns then
    BirdHouseRunner.Init();

  // Check and enable auto-retaliate
  WriteDebug('Init | Checking auto-retaliate setting...');
  if not Combat.GetAutoRetaliate() then
  begin
    WriteDebug('Init | Auto-retaliate disabled, enabling...');
    Combat.SetAutoRetaliate(True);
    Wait(300, 500);
  end
  else
    WriteDebug('Init | Auto-retaliate already enabled');

  // Check and set NPC attack option
  WriteDebug('Init | Checking NPC attack option...');
  if Options.GetNPCAttackOption() <> ERSAttackOption.ALWAYS_LEFT_CLICK then
  begin
    WriteDebug('Init | NPC attack option not set correctly, setting to left-click...');
    Options.SetNPCAttackOption(ERSAttackOption.ALWAYS_LEFT_CLICK);
    Wait(300, 500);
  end
  else
    WriteDebug('Init | NPC attack option already set to left-click');

  // Ensure chat is on 'All' tab to detect messages
  if not (ChatButtons.GetActive() in [ERSChatButton.ALL_CHAT, ERSChatButton.GAME_CHAT]) then
  begin
    WriteDebug('Init | Switching to All Chat tab...');
    ChatButtons.Open(ERSChatButton.ALL_CHAT);
    Wait(300, 500);
  end;

  // ===== ASCII art logo =====
  Writeln('');
  Writeln(' _____                                           _____ ');
  Writeln('( ___ )                                         ( ___ )');
  Writeln(' |   |~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~|   | ');
  Writeln(' |   |    _______  ______    ___   _  _______    |   | ');
  Writeln(' |   |   |       ||    _ |  |   | | ||   _   |   |   | ');
  Writeln(' |   |   |   _   ||   | ||  |   |_| ||  |_|  |   |   | ');
  Writeln(' |   |   |  | |  ||   |_||_ |      _||       |   |   | ');
  Writeln(' |   |   |  |_|  ||    __  ||     |_ |       |   |   | ');
  Writeln(' |   |   |       ||   |  | ||    _  ||   _   |   |   | ');
  Writeln(' |   |   |_______||___|  |_||___| |_||__| |__|   |   | ');
  Writeln(' |   |                                           |   | ');
  Writeln(' |___|~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~|___| ');
  Writeln('(_____)                                         (_____)');

  // ===== Credits block =====
  Writeln('');
  Writeln('  ___                                             ___  ');
  Writeln(' |   |****************  CREDITS  ****************|   | ');
  Writeln(' |   |                                           |   | ');
  Writeln(' |   |    3Garrett3  |  Torwent  |  Student      |   | ');
  Writeln(' |   |    BigAussie  |  Kriptic  |  Fik          |   | ');
  Writeln(' |   |    skunkworks |  unit     |  Sebastiaan   |   | ');
  Writeln(' |   |                                           |   | ');
  Writeln(' |___|~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~|___| ');
  Writeln('');

  // ===== Script configuration block =====
  Writeln('  ___                                             ___  ');
  Writeln(' |   |***********  Orka Reanimation  ************|   | ');
  Writeln(' |   |                                           |   | ');
  Writeln(' |   |    ' + PadR('Head Type: ' + GetHeadDisplayName(Self.HeadType), 39) + '|   | ');
  Writeln(' |   |    ' + PadR('Spell: ' + ToStr(Self.ReanimationSpell), 39) + '|   | ');
  if Self.BankLocation = EBankLocation.BANK_FEROX_ENCLAVE then
    Writeln(' |   |    ' + PadR('Bank: Ferox Enclave (Ring of Dueling)', 39) + '|   | ')
  else
    Writeln(' |   |    ' + PadR('Bank: Crafting Guild (Crafting Cape)', 39) + '|   | ');
  Writeln(' |   |    ' + PadR('Birdhouse Runs: ' + ToStr(Self.DoBHRuns), 39) + '|   | ');
  Writeln(' |   |                                           |   | ');
  Writeln(' |___|~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~|___| ');
  Writeln('');
end;

// -----------------------------------------------------------------------------
// Main Loop
// -----------------------------------------------------------------------------

(**
 * Run
 *
 * Entry point for the bot logic.
 * Contains the main loop and periodic reporting.
 *
 * @param maxActions Max actions
 * @param maxTime    Max runtime
 *)
procedure TReanimationBot.Run(maxActions: UInt32; maxTime: UInt64);
begin
  Self.Init(maxActions, maxTime);
  Self.WeaponSpecCost := 0; // Initialize unknown spec cost

  repeat
    Self.State := Self.GetState();
    Self.SetAction(ToStr(Self.State));

    // Periodic report
    if Self.ReportTimer.ElapsedTime() > 300000 then
    begin
      Self.Report();
      Self.ReportTimer.Reset();
    end;

    // Check for birdhouse run when safe (not in combat, logged in)
    if Self.DoBHRuns and (not Self.IsInCombat) and (not Self.MonsterSpawned) and RSClient.IsLoggedIn() then
    begin
      if BirdHouseRunner.ScriptIntervalTimer.IsFinished() then
      begin
        WriteDebug('BIRDHOUSE_RUN | Timer finished, starting birdhouse run...');
        BirdHouseRunner.DoBirdHouseRun();
        WriteDebug('BIRDHOUSE_RUN | Birdhouse run completed, resuming reanimation');
        Continue; // Re-evaluate state after birdhouse run
      end;
    end;

    // First run spell check
    if (not Self.VerifiedSpells) and RSClient.IsLoggedIn() then
    begin
      if not Self.CheckRequiredSpells() then
        TerminateScript('Missing required runes/spells or spellbook!');
      Self.VerifiedSpells := True;
    end;

    case Self.State of
      EReanimationState.HANDLE_LOGIN:
      begin
        WriteDebug('HANDLE_LOGIN | Logging in...');
        if Login.LoginPlayer() then
        begin
          WriteDebug('HANDLE_LOGIN | Successfully logged in');
          Wait(2000, 3000);
          WL.Activity.Restart();
        end
        else
        begin
          WriteDebug('HANDLE_LOGIN | Failed to log in, retrying...');
          Wait(3000, 5000);
        end;
      end;

      EReanimationState.TELEPORT_TO_BANK:
      begin
        Self.HandleQuickPrayers(False);
        if not Self.TeleportToBank() then
          Wait(2000, 3000);
      end;

      EReanimationState.USE_POOL:
      begin
        WriteDebug('USE_POOL | Drinking from Pool of Refreshment...');
        if not Self.DrinkFromPool() then
        begin
          WriteDebug('USE_POOL | Failed to use pool');
          Wait(1000, 2000);
        end;
      end;

      EReanimationState.OPEN_BANK:
      begin
        Self.HandleQuickPrayers(False);
        WriteDebug('OPEN_BANK | Opening bank...');
        if not Self.OpenBank() then
        begin
          WriteDebug('OPEN_BANK | Failed to open bank');
          Wait(1000, 2000);
        end;
      end;

      EReanimationState.HANDLE_BANK:
      begin
        WriteDebug('HANDLE_BANK | Handling bank...');
        if not Self.HandleBanking() then
        begin
          WriteDebug('HANDLE_BANK | Banking failed');
          if Bank.IsOpen() then
            Bank.Close();
          Wait(1000, 1500);
        end;
      end;

      EReanimationState.CLOSE_BANK:
      begin
        WriteDebug('CLOSE_BANK | Closing bank...');
        Bank.Close();
        Wait(400, 600);
      end;

      EReanimationState.TELEPORT_TO_ARCEUUS:
      begin
        WriteDebug('TELEPORT_TO_ARCEUUS | Teleporting to Arceuus Library...');
        if Self.TeleportToArceuus() then
        begin
          WriteDebug('TELEPORT_TO_ARCEUUS | Now walking to altar...');
          if Self.WalkToAltar() then
          begin
            Self.HandleQuickPrayers(True);
            Self.IsInCombat := False;
          end;
        end
        else
        begin
          WriteDebug('TELEPORT_TO_ARCEUUS | Failed to teleport');
          Wait(2000, 3000);
        end;
      end;

      EReanimationState.WALK_TO_ALTAR:
      begin
        WriteDebug('WALK_TO_ALTAR | Walking to altar...');
        if Self.WalkToAltar() then
          Self.HandleQuickPrayers(True);
      end;

      EReanimationState.CAST_REANIMATE:
      begin
        Self.HandleQuickPrayers(True);
        WriteDebug('CAST_REANIMATE | Casting reanimation spell...');

        if Self.CastReanimation() then
        begin
          // Try spec WHILE waiting for monster (most efficient timing)
          Self.AttemptSpec();

          // Wait for monster to spawn
          if Self.WaitForMonsterSpawn() then
          begin
            WriteDebug('CAST_REANIMATE | Monster spawned, attempting immediate attack...');

            // Try to attack immediately (with uptext check, no spam)
            if Self.AttackMonster() then
              WriteDebug('CAST_REANIMATE | Successfully attacked monster')
            else
              WriteDebug('CAST_REANIMATE | Initial attack failed, will retry via ATTACK_MONSTER state');
          end
          else
            WriteDebug('CAST_REANIMATE | Monster did not spawn');
        end
        else
        begin
          WriteDebug('CAST_REANIMATE | Failed to cast spell, checking for combat...');
          // Only check for combat if the cast failed
          if Self.IsActuallyInCombat() then
          begin
            WriteDebug('CAST_REANIMATE | Detected combat with hidden monster! Skipping cast...');
            Self.IsInCombat := True;
            Self.MonsterSpawned := False;
          end
          else
            Wait(1000, 2000);
        end;
      end;

      EReanimationState.WAIT_SPAWN:
      begin
        WriteDebug('WAIT_SPAWN | Waiting for monster spawn...');
        Self.WaitForMonsterSpawn();
      end;

      EReanimationState.ATTACK_MONSTER:
      begin
        // Pre-check: If we are already in combat (auto-retaliate kicked in), skip attacking
        if Self.IsActuallyInCombat() then
        begin
          WriteDebug('ATTACK_MONSTER | Already in combat (auto-retaliate). Switching to WAIT_COMBAT_END.');
          Self.IsInCombat := True;
          Self.MonsterSpawned := False;
          Wait(100);
          Continue;
        end;

        // Try to spec before attacking
        Self.AttemptSpec();

        WriteDebug('ATTACK_MONSTER | Attacking monster...');
        if not Self.AttackMonster() then
        begin
          Self.AttackAttempts += 1;

          // Check combat status immediately after failed attempt
          if Self.IsActuallyInCombat() then
          begin
            WriteDebug('ATTACK_MONSTER | Detected combat after failed attack! Switching to WAIT_COMBAT_END.');
            Self.IsInCombat := True;
            Self.MonsterSpawned := False;
            Wait(100);
            Continue;
          end;

          if Self.AttackAttempts > 5 then
          begin
            WriteDebug('ATTACK_MONSTER | Failed to find monster after 5 attempts. Monster appears to be gone.');
            Self.MonsterSpawned := False;
            Self.IsInCombat := False;
          end
          else
          begin
            WriteDebug('ATTACK_MONSTER | Failed to attack, retrying... (' + ToStr(Self.AttackAttempts) + '/10)');
            Wait(500, 1000);
          end;
        end;
      end;

      EReanimationState.WAIT_COMBAT_END:
      begin
        WriteDebug('WAIT_COMBAT_END | Waiting for combat to end...');
        Self.WaitCombatEnd();
      end;

      EReanimationState.RESET_POSITION:
      begin
        WriteDebug('RESET_POSITION | Resetting position to altar...');
        Self.ResetPosition();
      end;

      EReanimationState.EMERGENCY_HEAL:
      begin
        WriteDebug('EMERGENCY_HEAL | Low HP detected, teleporting to Ferox Enclave for healing...');
        Self.HandleQuickPrayers(False);
        Self.IsInCombat := False;
        Self.MonsterSpawned := False;
        Self.HasReachedStartTile := False;
        Self.HasUsedPool := False;
        if not Self.TeleportToFeroxEnclave() then
        begin
          WriteDebug('EMERGENCY_HEAL | Failed to teleport to Ferox Enclave');
          Wait(2000, 3000);
        end;
      end;

      EReanimationState.DO_ANTIBAN:
      begin
        Wait(100, 300);
      end;

      EReanimationState.END_SCRIPT:
      begin
        WriteLn('END_SCRIPT | Script ending...');
        Self.Report();
        Break;
      end;
    end;

    Self.DoAntiban();
  until Self.ShouldStop();

  // Final report
  Self.Report();
end;

(**
 * BuildTextReport
 *
 * Overrides WaspLib's default text report.
 * Returs empty array to disable default report since we use a custom one.
 *
 * @return Empty string array
 *)
function TReanimationBot.BuildTextReport(): TStringArray; override;
begin
  // Disable WaspLib's automatic progress reporting
  // Use custom Orka Report() instead (called every 5 minutes in main loop)
  Result := [];
end;

// -----------------------------------------------------------------------------
// GUI & Configuration
// -----------------------------------------------------------------------------

{$IFNDEF SCRIPT_CHAIN}
{$IFDEF SCRIPT_GUI}
type
  TReanimationConfig = record(TScriptForm)
    HeadLabel: TLabel;
    PotionLabel: TLabel;
    HeadSelector: TComboBox;
    UseSpecsCheckbox: TLabeledCheckBox;
    QuickPrayerCheckbox: TLabeledCheckBox;
    PotionCheckbox: TLabeledCheckBox;
    PotionSelector: TComboBox;
    BHRunsCheckbox: TLabeledCheckBox;
    BHLogLabel: TLabel;
    BHLogSelector: TComboBox;
    BHSeedLabel: TLabel;
    BHSeedEdit: TEdit;
    BHBestLogCheckbox: TLabeledCheckBox;
    BHCraftCheckbox: TLabeledCheckBox;
    BHIntervalLabel: TLabel;
    BHNowRadio: TRadioButton;
    BHNowLabel: TLabel;
    BHLaterRadio: TRadioButton;
    BHLaterLabel: TLabel;
  end;

var
  ReanimationConfig: TReanimationConfig;

(**
 * SaveConfig
 *
 * Saves the current GUI configuration settings to the script config file.
 *)
procedure SaveConfig();
begin
  if not Config.IsSetup then
    Config.Setup('orka-reanimation');

  Config.Put('headType', ReanimationConfig.HeadSelector.GetItemIndex());
  Config.Put('useSpecs', ReanimationConfig.UseSpecsCheckbox.IsChecked());
  Config.Put('useQuickPrayers', ReanimationConfig.QuickPrayerCheckbox.IsChecked());
  Config.Put('useBankPotion', ReanimationConfig.PotionCheckbox.IsChecked());
  Config.Put('bankPotionType', ReanimationConfig.PotionSelector.GetItemIndex());
  Config.Put('doBHRuns', ReanimationConfig.BHRunsCheckbox.IsChecked());

  // Save birdhouse settings
  Config.Put('bhLogType', Ord(BirdHouseRunner.LogType));
  Config.Put('bhSeed', ToStr(BirdHouseRunner.Seed));
  Config.Put('bhUseBestLog', BirdHouseRunner.AlwaysUseBestLog);
  Config.Put('bhCraftWhileWalking', BirdHouseRunner.NeedClockworks);
end;

(**
 * LoadConfig
 *
 * Loads configuration settings from the script config file into the GUI.
 * Sets default values if config entries are missing.
 *)
procedure LoadConfig();
var
  potionIndex: Int32;
begin
  if not Config.IsSetup then
    Config.Setup('orka-reanimation');

  if Config.Has('headType') then
    ReanimationConfig.HeadSelector.SetItemIndex(Config.GetInt('headType'))
  else
    ReanimationConfig.HeadSelector.SetItemIndex(8); // Default to Dragon

  if Config.Has('useSpecs') then
    ReanimationConfig.UseSpecsCheckbox.SetChecked(Config.GetBoolean('useSpecs'))
  else
    ReanimationConfig.UseSpecsCheckbox.SetChecked(True); // Default to True

  if Config.Has('useQuickPrayers') then
    ReanimationConfig.QuickPrayerCheckbox.SetChecked(Config.GetBoolean('useQuickPrayers'))
  else
    ReanimationConfig.QuickPrayerCheckbox.SetChecked(False);

  potionIndex := 0; // Default to combat potion
  if Config.Has('bankPotionType') then
  begin
    potionIndex := Config.GetInt('bankPotionType');
    if potionIndex < 0 then
      potionIndex := 0
    else if potionIndex > Ord(High(EPotionType)) then
      potionIndex := 0;
  end;
  ReanimationConfig.PotionSelector.SetItemIndex(potionIndex);

  if Config.Has('useBankPotion') then
    ReanimationConfig.PotionCheckbox.SetChecked(Config.GetBoolean('useBankPotion'))
  else
    ReanimationConfig.PotionCheckbox.SetChecked(False);

  if Config.Has('doBHRuns') then
    ReanimationConfig.BHRunsCheckbox.SetChecked(Config.GetBoolean('doBHRuns'));

  // Load birdhouse settings and update GUI defaults
  if Config.Has('bhLogType') then
  begin
    BirdHouseRunner.LogType := ERSLogType(Config.GetInt('bhLogType'));
    BHIncludeGUILogType := BirdHouseRunner.LogType;
  end;

  if Config.Has('bhSeed') then
  begin
    BirdHouseRunner.Seed := Config.GetString('bhSeed');
    BHIncludeGUISeed := BirdHouseRunner.Seed;
  end;

  if Config.Has('bhUseBestLog') then
  begin
    BirdHouseRunner.AlwaysUseBestLog := Config.GetBoolean('bhUseBestLog');
    BHIncludeGUIUseBestLog := BirdHouseRunner.AlwaysUseBestLog;
  end;

  if Config.Has('bhCraftWhileWalking') then
    BirdHouseRunner.NeedClockworks := Config.GetBoolean('bhCraftWhileWalking')
  else if Config.Has('bhNeedClockworks') then
    BirdHouseRunner.NeedClockworks := Config.GetBoolean('bhNeedClockworks');
  BHIncludeGUICraftWhileNav := BirdHouseRunner.NeedClockworks;

  BHIncludeGUIRunIntervalMinutes := 50; // Default to run later

  if Config.Has('bhTaskInterval') then
  begin
    BirdHouseRunner.TaskInterval := Config.GetInt('bhTaskInterval');
    if BirdHouseRunner.TaskInterval = 0 then
      BHIncludeGUIRunIntervalMinutes := 0;
  end;
end;

(**
 * TReanimationConfig.StartScript
 *
 * GUI Start button callback.
 * Applies GUI settings to the bot configuration and starts the script.
 *
 * @param sender The object that triggered the event
 *)
procedure TReanimationConfig.StartScript(sender: TObject); override;
var
  potionIndex: Int32;
begin
  Bot.HeadType := EHeadType(Self.HeadSelector.GetItemIndex());
  Bot.DoBHRuns := Self.BHRunsCheckbox.IsChecked();
  Bot.UseSpecs := Self.UseSpecsCheckbox.IsChecked();
  Bot.UseQuickPrayers := Self.QuickPrayerCheckbox.IsChecked();
  Bot.UseBankPotion := Self.PotionCheckbox.IsChecked();

  potionIndex := Self.PotionSelector.GetItemIndex();
  if potionIndex < 0 then
    potionIndex := 0
  else if potionIndex > Ord(High(EPotionType)) then
    potionIndex := Ord(High(EPotionType));
  Bot.BankPotion := EPotionType(potionIndex);

  // Set bank location to Ferox Enclave (only GUI option for now)
  Bot.BankLocation := EBankLocation.BANK_FEROX_ENCLAVE;
  // Bot.BankLocation := EBankLocation.BANK_CRAFTING_GUILD; // Reactivate if needed

  SaveConfig();
  inherited;
end;

(**
 * TReanimationConfig.CreateBirdhouseRunSettings
 *
 * Creates the "Birdhouse Settings" tab in the GUI.
 * Includes controls for logs, seeds, and run behavior.
 *
 * @return The created tab sheet
 *)
function TReanimationConfig.CreateBirdhouseRunSettings(): TTabSheet; override;
  type TReanimationConfig = TReanimationConfig;

  (**
   * _BHSeedChanged
   * Callback for seed text edit changes.
   *)
  procedure TReanimationConfig._BHSeedChanged(sender: TObject);
  var
    seed: TEdit;
  begin
    seed := sender;
    BirdHouseRunner.Seed := seed.getText();
  end;

  (**
   * _BHLogTypeChanged
   * Callback for log type dropdown changes.
   *)
  procedure TReanimationConfig._BHLogTypeChanged(sender: TObject);
  var
    combobox: TComboBox;
  begin
    combobox := sender;
    BirdHouseRunner.LogType := ERSLogType(comboBox.getItemIndex());
  end;

  (**
   * _BHCheckBoxChanged
   * Callback for birdhouse configuration checkboxes.
   *)
  procedure TReanimationConfig._BHCheckBoxChanged(sender: TObject);
  var
    checkBox: TCheckBox;
    isChecked: Boolean;
  begin
    checkBox := sender;
    isChecked := checkBox.IsChecked();
    case checkBox.getName() of
      'bh_extraclockworkcb_checkbox': BirdHouseRunner.NeedClockworks := isChecked;
      'bh_bestlogcb_checkbox': BirdHouseRunner.AlwaysUseBestLog := isChecked;
    end;
  end;

  (**
   * _BHRadioChanged
   * Callback for birdhouse timing radio buttons.
   *)
  procedure TReanimationConfig._BHRadioChanged(sender: TObject);
  var
    radio: TRadioButton;
  begin
    radio := sender;
    case radio.getName() of
      'bh_nowradio': BirdHouseRunner.TaskInterval := 0;
      'bh_laterradio': BirdHouseRunner.TaskInterval := 50 * ONE_MINUTE;
    end;
  end;

var
  baseLeft, baseTop, controlWidth, spacing, indent, labelGap, currentTop: Int32;
begin
  Self.AddTab('Birdhouse Settings');
  Result := Self.Tabs[High(Self.Tabs)];

  controlWidth := TControl.AdjustToDPI(240);
  baseLeft := TControl.AdjustToDPI(60);
  baseTop := TControl.AdjustToDPI(170);
  spacing := TControl.AdjustToDPI(10);
  indent := TControl.AdjustToDPI(18);
  labelGap := TControl.AdjustToDPI(4);
  currentTop := baseTop;

  with Self.BHLogLabel do
  begin
    Create(Result);
    SetCaption('Log type to use:');
    SetLeft(baseLeft);
    SetTop(currentTop);
    SetFontColor($FFFFFF);
    GetFont.SetStyle([fsBold]);
  end;

  with Self.BHLogSelector do
  begin
    Create(Result);
    SetLeft(baseLeft);
    SetTop(Self.BHLogLabel.GetTop() + Self.BHLogLabel.GetHeight() + labelGap);
    SetWidth(controlWidth);
    SetStyle(csDropDownList);
    AddItem('Regular', nil);
    AddItem('Oak', nil);
    AddItem('Willow', nil);
    AddItem('Teak', nil);
    AddItem('Maple', nil);
    AddItem('Mahogany', nil);
    AddItem('Yew', nil);
    AddItem('Magic tree', nil);
    AddItem('Redwood', nil);
    BirdHouseRunner.LogType := BHIncludeGUILogType;
    SetItemIndex(Ord(BirdHouseRunner.LogType));
    SetOnChange(@Self._BHLogTypeChanged);
  end;

  currentTop := Self.BHLogSelector.GetTop() + Self.BHLogSelector.GetHeight() + spacing;

  with Self.BHSeedLabel do
  begin
    Create(Result);
    SetCaption('Seed (just the name, e.g. potato):');
    SetLeft(baseLeft);
    SetTop(currentTop);
    SetFontColor($FFFFFF);
    GetFont.SetStyle([fsBold]);
  end;

  with Self.BHSeedEdit do
  begin
    Create(Result);
    SetLeft(baseLeft);
    SetTop(Self.BHSeedLabel.GetTop() + Self.BHSeedLabel.GetHeight() + labelGap);
    SetWidth(controlWidth);
    SetName('bh_seed');
    BirdHouseRunner.Seed := ToStr(BHIncludeGUISeed).Replace('Barely', 'Barley', [rfIgnoreCase]).Before(' ');
    SetText(ToStr(BirdHouseRunner.Seed));
    SetOnChange(@Self._BHSeedChanged);
    GetFont.SetColor($000000);
  end;

  currentTop := Self.BHSeedEdit.GetTop() + Self.BHSeedEdit.GetHeight() + spacing;

  with Self.BHBestLogCheckbox do
  begin
    Create(Result);
    SetLeft(baseLeft);
    SetTop(currentTop);
    SetName('bh_bestlogcb');
    SetCaption('Always use best log');
    SetWidth(TControl.AdjustToDPI(450));
    SetFontColor($FFFFFF);
    Caption.GetFont().SetStyle([fsBold]);
    BirdHouseRunner.AlwaysUseBestLog := BHIncludeGUIUseBestLog;
    SetChecked(BirdHouseRunner.AlwaysUseBestLog);
    CheckBox.setOnChange(@Self._BHCheckBoxChanged);
  end;

  currentTop := Self.BHBestLogCheckbox.GetTop() + Self.BHBestLogCheckbox.GetHeight() + spacing;

  with Self.BHCraftCheckbox do
  begin
    Create(Result);
    SetLeft(baseLeft);
    SetTop(currentTop);
    SetName('bh_extraclockworkcb');
    SetCaption('Craft birdhouses while navigating (requires clockwork in bank)');
    SetWidth(TControl.AdjustToDPI(450));
    SetFontColor($FFFFFF);
    Caption.GetFont().SetStyle([fsBold]);
    BirdHouseRunner.NeedClockworks := BHIncludeGUICraftWhileNav;
    SetChecked(BirdHouseRunner.NeedClockworks);
    CheckBox.setOnChange(@Self._BHCheckBoxChanged);
  end;

  currentTop := Self.BHCraftCheckbox.GetTop() + Self.BHCraftCheckbox.GetHeight() + spacing + TControl.AdjustToDPI(10);

  with Self.BHIntervalLabel do
  begin
    Create(Result);
    SetCaption('When should the next run start?');
    SetLeft(baseLeft);
    SetTop(currentTop);
    SetFontColor($FFFFFF);
    GetFont.SetStyle([fsBold]);
  end;

  currentTop := Self.BHIntervalLabel.GetTop() + Self.BHIntervalLabel.GetHeight() + labelGap;

  with Self.BHNowRadio do
  begin
    Create(Result);
    SetName('bh_nowradio');
    SetLeft(baseLeft + indent);
    SetTop(currentTop);
    SetWidth(TControl.AdjustToDPI(18));
    SetCaption('');
    SetOnClick(@Self._BHRadioChanged);
  end;

  with Self.BHNowLabel do
  begin
    Create(Result);
    SetCaption('Do a run now');
    SetLeft(Self.BHNowRadio.GetLeft() + Self.BHNowRadio.GetWidth());
    SetTop(currentTop);
    SetFontColor($FFFFFF);
    GetFont.SetStyle([fsBold]);
  end;

  currentTop := Self.BHNowRadio.GetTop() + Self.BHNowRadio.GetHeight() + labelGap;

  with Self.BHLaterRadio do
  begin
    Create(Result);
    SetName('bh_laterradio');
    SetLeft(baseLeft + indent);
    SetTop(currentTop);
    SetWidth(TControl.AdjustToDPI(18));
    SetCaption('');
    SetOnClick(@Self._BHRadioChanged);
  end;

  with Self.BHLaterLabel do
  begin
    Create(Result);
    SetCaption('Do a run later (in about 50-60 minutes)');
    SetLeft(Self.BHLaterRadio.GetLeft() + Self.BHLaterRadio.GetWidth());
    SetTop(currentTop);
    SetFontColor($FFFFFF);
    GetFont.SetStyle([fsBold]);
  end;

  BirdHouseRunner.TaskInterval := BHIncludeGUIRunIntervalMinutes;

  if BHIncludeGUIRunIntervalMinutes > 0 then
  begin
    Self.BHLaterRadio.setState(TCheckBoxState.cbChecked);
    Self.BHNowRadio.setState(TCheckBoxState.cbUnchecked);
    BirdHouseRunner.TaskInterval := 50 * ONE_MINUTE;
  end
  else
  begin
    Self.BHLaterRadio.setState(TCheckBoxState.cbUnchecked);
    Self.BHNowRadio.setState(TCheckBoxState.cbChecked);
    BirdHouseRunner.TaskInterval := 0;
  end;
end;

(**
 * TReanimationConfig.Run
 *
 * Initializes and displays the script configuration GUI.
 *)
procedure TReanimationConfig.Run(); override;
var
  tab, accountTab: TTabSheet;
  Font: TFont;
  Img: TPicture;
  BGImg: TImage;
  baseLeft, baseTop, controlWidth, spacing, indent, labelGap, currentTop, startTop: Int32;
begin
  Self.Setup('Orka Reanimation');
  Self.Start.setOnClick(@Self.StartScript);

  Font.Init();
  Font.setName('Verdana');
  Font.SetQuality(fqCleartype);
  Self.Form.setFont(Font);
  Self.PageControl.SetFont(Font);
  Font.Free();

  // Set background on PageControl (like aeroguardians) so TLabeledCheckBox panels appear transparent
  if not FileExists(AppPath + 'Resources\OrkaReanimationBG.jpeg') then
    DownloadToFile('https://i.imgur.com/l7YzMvK.jpeg', AppPath + 'Resources\OrkaReanimationBG.jpeg');

  if FileExists(AppPath + 'Resources\OrkaReanimationBG.jpeg') then
  begin
    Img.Init();
    Img.LoadFromFile(AppPath + 'Resources\OrkaReanimationBG.jpeg');
    with BGImg do
    begin
      Init(Self.PageControl);
      SetParent(Self.PageControl);
      SetPicture(Img);
      SetBounds(0, 0, Self.Form.GetWidth(), Self.Form.GetHeight());
      SetStretch(True);
      AdjustToDPI(GetScreenDPI);
    end;
  end;

  Self.AddTab('Script Settings');
  tab := Self.Tabs[High(Self.Tabs)];

  controlWidth := TControl.AdjustToDPI(240);
  baseLeft := TControl.AdjustToDPI(60);
  baseTop := TControl.AdjustToDPI(170);
  spacing := TControl.AdjustToDPI(10);
  indent := TControl.AdjustToDPI(18);
  labelGap := TControl.AdjustToDPI(4);
  currentTop := baseTop;

  with Self.HeadLabel do
  begin
    Create(tab);
    SetCaption('Ensouled head:');
    SetLeft(baseLeft);
    SetTop(currentTop);
    SetFontColor($FFFFFF);
    GetFont.SetStyle([fsBold]);
  end;

  with Self.HeadSelector do
  begin
    Create(tab);
    SetLeft(baseLeft);
    SetTop(Self.HeadLabel.GetTop() + Self.HeadLabel.GetHeight() + labelGap);
    SetWidth(controlWidth);
    SetStyle(csDropDownList);
    AddItem('Abyssal', nil);
    AddItem('Aviansie', nil);
    AddItem('Bear', nil);
    AddItem('Bloodveld', nil);
    AddItem('Chaos Druid', nil);
    AddItem('Dagannoth', nil);
    AddItem('Demon', nil);
    AddItem('Dog', nil);
    AddItem('Dragon', nil);
    AddItem('Elf', nil);
    AddItem('Giant', nil);
    AddItem('Goblin', nil);
    AddItem('Hellhound', nil);
    AddItem('Horror', nil);
    AddItem('Imp', nil);
    AddItem('Kalphite', nil);
    AddItem('Minotaur', nil);
    AddItem('Monkey', nil);
    AddItem('Ogre', nil);
    AddItem('Scorpion', nil);
    AddItem('Troll', nil);
    AddItem('TzHaar', nil);
    AddItem('Unicorn', nil);
    SetItemIndex(8); // Default to Dragon
  end;

  currentTop := Self.HeadSelector.GetTop() + Self.HeadSelector.GetHeight() + spacing;

  with Self.UseSpecsCheckbox do
  begin
    Create(tab);
    SetLeft(baseLeft);
    SetTop(currentTop);
    SetName('use_specs');
    SetCaption('Use special attacks');
    SetWidth(TControl.AdjustToDPI(450));
    SetFontColor($FFFFFF);
    Caption.GetFont().SetStyle([fsBold]);
    SetChecked(True);
  end;

  currentTop := Self.UseSpecsCheckbox.GetTop() + Self.UseSpecsCheckbox.GetHeight() + spacing;

  with Self.QuickPrayerCheckbox do
  begin
    Create(tab);
    SetLeft(baseLeft);
    SetTop(currentTop);
    SetName('quick_prayer');
    SetCaption('Enable quick prayers');
    SetWidth(TControl.AdjustToDPI(450));
    SetFontColor($FFFFFF);
    Caption.GetFont().SetStyle([fsBold]);
    SetChecked(False);
  end;

  currentTop := Self.QuickPrayerCheckbox.GetTop() + Self.QuickPrayerCheckbox.GetHeight() + spacing;

  with Self.PotionCheckbox do
  begin
    Create(tab);
    SetLeft(baseLeft);
    SetTop(currentTop);
    SetName('bank_potion');
    SetCaption('Drink combat potion (1-dose) when banking');
    SetWidth(TControl.AdjustToDPI(450));
    SetFontColor($FFFFFF);
    Caption.GetFont().SetStyle([fsBold]);
    SetChecked(False);
  end;

  currentTop := Self.PotionCheckbox.GetTop() + Self.PotionCheckbox.GetHeight() + spacing;

  with Self.PotionLabel do
  begin
    Create(tab);
    SetCaption('Potion type:');
    SetLeft(baseLeft + indent);
    SetTop(currentTop);
    SetFontColor($FFFFFF);
    GetFont.SetStyle([fsBold]);
  end;

  with Self.PotionSelector do
  begin
    Create(tab);
    SetLeft(baseLeft + indent);
    SetTop(Self.PotionLabel.GetTop() + Self.PotionLabel.GetHeight() + labelGap);
    SetWidth(controlWidth - indent);
    SetStyle(csDropDownList);
    AddItem('Combat', nil);
    AddItem('Attack', nil);
    AddItem('Strength', nil);
    AddItem('Super Attack', nil);
    AddItem('Super Strength', nil);
    AddItem('Super Combat', nil);
    AddItem('Ranging', nil);
    SetItemIndex(0);
  end;

  currentTop := Self.PotionSelector.GetTop() + Self.PotionSelector.GetHeight() + spacing + TControl.AdjustToDPI(20);

  with Self.BHRunsCheckbox do
  begin
    Create(tab);
    SetLeft(baseLeft);
    SetTop(currentTop);
    SetName('bh_runs');
    SetCaption('Enable birdhouse runs');
    SetWidth(TControl.AdjustToDPI(450));
    SetFontColor($FFFFFF);
    Caption.GetFont().SetStyle([fsBold]);
    SetChecked(False);
  end;

  with Self.Start do
  begin
    SetAlign(alNone);
    SetWidth(controlWidth);
    SetHeight(TControl.AdjustToDPI(40));
    SetLeft(baseLeft);
    startTop := Max(
      Self.Form.GetHeight() - GetHeight() - TControl.AdjustToDPI(50),
      Self.BHRunsCheckbox.GetTop() + Self.BHRunsCheckbox.GetHeight() + TControl.AdjustToDPI(16)
    );
    SetTop(startTop);
  end;

  // Account Manager Tab
  Self.AddTab('Account Manager');
  accountTab := Self.Tabs[High(Self.Tabs)];
  Self.CreateAccountManager(accountTab);

  LoadConfig();

  Self.CreateAntibanManager();
  Self.CreateWaspLibSettings();

  // Birdhouse Settings Tab (from birdhouserunner.simba)
  Self.CreateBirdhouseRunSettings();

  Self.PageControl.SetChildsFontColor($FFFFFF);

  inherited;
end;
{$ENDIF}
{$ENDIF}

// -----------------------------------------------------------------------------
// Entry Point
// -----------------------------------------------------------------------------

begin
  {$IFDEF SCRIPT_GUI}
  ReanimationConfig.Run();
  {$ENDIF}
  Bot.Run(WLSettings.MaxActions, WLSettings.MaxTime);
end.
