    HEAD_CHAOS_DRUID: Result := 'Chaos Druid';
    HEAD_DAGANNOTH:   Result := 'Dagannoth';
    HEAD_DEMON:       Result := 'Demon';
    HEAD_DOG:         Result := 'Dog';
    HEAD_DRAGON:      Result := 'Dragon';
    HEAD_ELF:         Result := 'Elf';
    HEAD_GIANT:       Result := 'Giant';
    HEAD_GOBLIN:      Result := 'Goblin';
    HEAD_HELLHOUND:   Result := 'Hellhound';
    HEAD_HORROR:      Result := 'Horror';
    HEAD_IMP:         Result := 'Imp';
    HEAD_KALPHITE:    Result := 'Kalphite';
    HEAD_MINOTAUR:    Result := 'Minotaur';
    HEAD_MONKEY:      Result := 'Monkey';
