{$DEFINE SCRIPT_REVISION := '5'}
{$IFNDEF SCRIPT_CHAIN}
  {$DEFINE SCRIPT_GUI}
  program OrkaReanimation;
  {$I SRL-T/osr.simba}
  {$I WaspLib/osr.simba}
  {$I WaspLib/optional/handlers/teleports/transport.simba}
  {$I WaspLib/optional/handlers/birdhouserunner.simba}
{$ENDIF}

const
  SCRIPT_NAME = 'Orka Reanimation';
  VERBOSE_LOGGING = True;
  MIN_HEALTH_PERCENT = 40;
  SPEC_USE_CHANCE = 70;

  // Prayer XP Drop DTM for kill detection
  PRAYER_XP_DTM = 'mGQAAAHicY2RgYLjFyMDQD6Qfvr/OAAKMIAIAO4oEFA==';

  // Area definitions
  ARCEUUS_AREA: TBox = [2332, 34826, 2900, 35162];
  ARCEUUS_LIBRARY_BOX: TBox = [2400, 35050, 2472, 35098];
  CRAFTING_GUILD_BOX: TBox = [7580, 37240, 7680, 37360];
  FEROX_ENCLAVE_BOX: TBox = [8350, 35850, 8550, 36000];

  // Altar positioning tiles
  ALTAR_START_TILE: TPoint = [2744, 34910];
  ALTAR_RESET_TILE: TPoint = [2716, 34910];

  // Bank tile in crafting guild
  CRAFTING_GUILD_BANK_TILE: TPoint = [7648, 37310];

  // Ferox Enclave tiles
  FEROX_POOL_TILE: TPoint = [8418, 35896];
  FEROX_BANK_TILE: TPoint = [8424, 35902];

  // Ring of dueling chat message when crumbled
  RING_CRUMBLED_MESSAGE = 'crumbles to dust';
  NO_ROOM_MESSAGE = 'room to re-animate';

type
  EHeadType = (
    HEAD_ABYSSAL,
    HEAD_AVIANSIE,
    HEAD_BEAR,
    HEAD_BLOODVELD,
    HEAD_CHAOS_DRUID,
    HEAD_DAGANNOTH,
    HEAD_DEMON,
    HEAD_DOG,
    HEAD_DRAGON,
    HEAD_ELF,
    HEAD_GIANT,
    HEAD_GOBLIN,
    HEAD_HELLHOUND,
    HEAD_HORROR,
    HEAD_IMP,
    HEAD_KALPHITE,
    HEAD_MINOTAUR,
    HEAD_MONKEY,
    HEAD_OGRE,
    HEAD_SCORPION,
    HEAD_TROLL,
    HEAD_TZHAAR,
    HEAD_UNICORN
  );

  EReanimationState = (
    HANDLE_LOGIN,
    TELEPORT_TO_BANK,
    USE_POOL,
    OPEN_BANK,
    HANDLE_BANK,
    CLOSE_BANK,
    TELEPORT_TO_ARCEUUS,
    WALK_TO_ALTAR,
    CAST_REANIMATE,
    WAIT_SPAWN,
    ATTACK_MONSTER,
    WAIT_COMBAT_END,
    RESET_POSITION,
    DO_ANTIBAN,
    EMERGENCY_HEAL,
    END_SCRIPT
  );

  EPotionType = (
    POTION_COMBAT,
    POTION_ATTACK,
    POTION_STRENGTH,
    POTION_SUPER_ATTACK,
    POTION_SUPER_STRENGTH,
    POTION_SUPER_COMBAT,
    POTION_RANGING
  );

  EBankLocation = (
    BANK_CRAFTING_GUILD,
    BANK_FEROX_ENCLAVE
  );

  TReanimationBot = record(TBaseWalkerScript)
    State: EReanimationState;

    // Configuration
    HeadType: EHeadType;
    HeadItem: TRSItem;
    ReanimationSpell: ERSSpell;
    DoBHRuns: Boolean;
    UseSpecs: Boolean;
    UseQuickPrayers: Boolean;
    UseBankPotion: Boolean;
    BankPotion: EPotionType;
    BankLocation: EBankLocation;

    // Position tracking
    CurrentTile: TPoint;
    SpawnTile: TPoint;

    // Combat tracking
    IsInCombat: Boolean;
    MonsterSpawned: Boolean;
    HasReachedStartTile: Boolean;
    AttackAttempts: Int32;
    WalkFailureCount: Int32;  // Track consecutive walk failures

    // Ferox Enclave tracking
    HasUsedPool: Boolean;       // True after using pool, reset when banking complete
    NeedsNewRing: Boolean;      // True when ring crumbled, need to get new one from bank
    NeedsManualReset: Boolean;  // True when "no room" message seen
    NeedsEmergencyHeal: Boolean; // True when HP is low, need to teleport to Ferox for healing
    LastNoRoomCount: Int32;     // Track number of "no room" messages to detect new ones

    // Stats
    HeadsUsed, MonstersKilled: Int32;
    HeadPendingXP: Boolean; // True after consuming a head until a prayer XP drop is seen
    HeadCount: Int32;  // Current heads in inventory

    // Break tracking
    TotalBreakTime, LastBreakStartTime, LastBreakEndTime: Int64;

    // Report timer
    ReportTimer: TStopwatch;

    // Spec Attack Logic
    WeaponSpecCost: Int32;

    // Potion availability cache
    CombatPotionUnavailable: Boolean;   // True when combat potion withdrawal fails
    AntifirePotionUnavailable: Boolean; // True when both antifire variants fail

    // Run verification
    VerifiedSpells: Boolean;

  end;


var
  Bot: TReanimationBot;
  Config: TConfigJSON;

// -----------------------------------------------------------------------------
// Head Type Mappings
// -----------------------------------------------------------------------------

(**
 * GetHeadItemName
 *
 * Returns the full item name for a given head type.
 *
 * @param headType  The enum value of the head
 * @return          The string name of the item
 *)
function GetHeadItemName(headType: EHeadType): String;
begin
  case headType of
    HEAD_ABYSSAL:     Result := 'Ensouled abyssal head';
    HEAD_AVIANSIE:    Result := 'Ensouled aviansie head';
    HEAD_BEAR:        Result := 'Ensouled bear head';
    HEAD_BLOODVELD:   Result := 'Ensouled bloodveld head';
    HEAD_CHAOS_DRUID: Result := 'Ensouled chaos druid head';
    HEAD_DAGANNOTH:   Result := 'Ensouled dagannoth head';
    HEAD_DEMON:       Result := 'Ensouled demon head';
    HEAD_DOG:         Result := 'Ensouled dog head';
    HEAD_DRAGON:      Result := 'Ensouled dragon head';
    HEAD_ELF:         Result := 'Ensouled elf head';
    HEAD_GIANT:       Result := 'Ensouled giant head';
    HEAD_GOBLIN:      Result := 'Ensouled goblin head';
    HEAD_HELLHOUND:   Result := 'Ensouled hellhound head';
    HEAD_HORROR:      Result := 'Ensouled horror head';
    HEAD_IMP:         Result := 'Ensouled imp head';
    HEAD_KALPHITE:    Result := 'Ensouled kalphite head';
    HEAD_MINOTAUR:    Result := 'Ensouled minotaur head';
    HEAD_MONKEY:      Result := 'Ensouled monkey head';
    HEAD_OGRE:        Result := 'Ensouled ogre head';
    HEAD_SCORPION:    Result := 'Ensouled scorpion head';
    HEAD_TROLL:       Result := 'Ensouled troll head';
    HEAD_TZHAAR:      Result := 'Ensouled tzhaar head';
    HEAD_UNICORN:     Result := 'Ensouled unicorn head';
  end;
end;

(**
 * GetReanimationSpell
 *
 * Maps a head type to the required reanimation spell tier.
 *
 * @param headType  The head to reanimate
 * @return          The required spell enum
 *)
function GetReanimationSpell(headType: EHeadType): ERSSpell;
begin
  case headType of
    HEAD_BEAR, HEAD_GOBLIN, HEAD_IMP, HEAD_MINOTAUR,
    HEAD_MONKEY, HEAD_SCORPION, HEAD_UNICORN:
      Result := ERSSpell.BASIC_REANIMATION;

    HEAD_CHAOS_DRUID, HEAD_DOG, HEAD_ELF, HEAD_GIANT,
    HEAD_HORROR, HEAD_OGRE, HEAD_TROLL:
      Result := ERSSpell.ADEPT_REANIMATION;

    HEAD_BLOODVELD, HEAD_DAGANNOTH, HEAD_DEMON,
    HEAD_HELLHOUND, HEAD_KALPHITE, HEAD_TZHAAR:
      Result := ERSSpell.EXPERT_REANIMATION;

    HEAD_ABYSSAL, HEAD_AVIANSIE, HEAD_DRAGON:
      Result := ERSSpell.MASTER_REANIMATION;
  end;
end;

