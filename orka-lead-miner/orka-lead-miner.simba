procedure SetupDungeonExit();
begin
  PandemoniumObjects.DungeonExit.SetupEx([3, 0.8, 8], [[8072, 12840]]);
  PandemoniumObjects.DungeonExit.SetupUpText(['Opening']);
  PandemoniumObjects.DungeonExit.Finder.Colors += [CTS2(4869711, 5, 0.74, 0.15)];
  PandemoniumObjects.DungeonExit.Finder.Grow := 15;
  PandemoniumObjects.DungeonExit.Walker := @Map.Walker;
  PandemoniumObjects.DungeonExit.TrackTarget := False;
