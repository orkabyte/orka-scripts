begin
  PandemoniumObjects.DungeonEntrance.SetupEx([1.8, 1.2, 7], [[8088, 38440]]);
  PandemoniumObjects.DungeonEntrance.SetupUpText(['Cave','entrance']);
  PandemoniumObjects.DungeonEntrance.Finder.Colors += [CTS2(4481126, 19, 0.16, 0.35)];
