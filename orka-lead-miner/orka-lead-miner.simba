  // Rock 2 at [8144, 12930]
  PandemoniumObjects.LeadRock2.SetupEx([1, 1, 3], [[8144, 12930]]);
  PandemoniumObjects.LeadRock2.SetupUpText(['Lead']);
  PandemoniumObjects.LeadRock2.Finder.Colors += [CTS2(8681099, 8, 3.15, 0.73)];
  PandemoniumObjects.LeadRock2.Finder.Erode := 4;
  PandemoniumObjects.LeadRock2.Finder.Grow := 5;
  PandemoniumObjects.LeadRock2.Walker := @Map.Walker;

  // Rock 3 at [8144, 12934]
  PandemoniumObjects.LeadRock3.SetupEx([1, 1, 3], [[8144, 12934]]);
  PandemoniumObjects.LeadRock3.SetupUpText(['Lead']);
  PandemoniumObjects.LeadRock3.Finder.Colors += [CTS2(8681099, 8, 3.15, 0.73)];
  PandemoniumObjects.LeadRock3.Finder.Erode := 4;
  PandemoniumObjects.LeadRock3.Finder.Grow := 5;
  PandemoniumObjects.LeadRock3.Walker := @Map.Walker;

  // Rock 4 at [8136, 12938]
  PandemoniumObjects.LeadRock4.SetupEx([1, 1, 3], [[8136, 12938]]);
  PandemoniumObjects.LeadRock4.SetupUpText(['Lead']);
  PandemoniumObjects.LeadRock4.Finder.Colors += [CTS2(8681099, 8, 3.15, 0.73)];
