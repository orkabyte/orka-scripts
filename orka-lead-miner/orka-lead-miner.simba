{$DEFINE SCRIPT_REVISION := '1'}
{$DEFINE SCRIPT_GUI}
program OrkaLeadMiner;
{$I SRL-T/osr.simba}
{$I WaspLib/osr.simba}

const
  VERBOSE_LOGGING = True;
  LEAD_ORE_NAME = 'Lead ore';

type
  TGUI = record(TScriptForm)
    lab_Title, lab_Info, lab_BreakSettings: TLabel;
    edit_BreakAfter, edit_BreakFor, edit_ShutdownAfter: TLabeledEdit;
    edit_SleepAtTime, edit_SleepForHours: TLabeledEdit;
    cb_BlockInput, cb_TakeBreaks, cb_TakeSleeps: TLabeledCheckbox;
  end;

  TPandemoniumObjects = record
    LeadRock1, LeadRock2, LeadRock3, LeadRock4: TRSObjectV2;
    DungeonExit: TRSObjectV2;
    DungeonEntrance: TRSObjectV2;
    Bank: TRSObjectV2;
  end;

  EState = (HANDLE_LOGIN, CLOSE_INTERFACE, BANKING, ENTER_CAVE,
            GO_TO_ROCKS, MINE_ORE, EXIT_CAVE, DO_ANTIBAN);

var
  PandemoniumObjects: TPandemoniumObjects;
  GUI: TGUI;
  Config: TConfigJSON;
  TakeBreaks, TakeSleeps: Boolean;
  BreakFor, BreakAfter: Int32;
  SleepAtTime: String;
  SleepForHours: Int32;
  ShutdownTime: Int64;
  StartXP, GainedXP: Int32;
  LeadOresMined, LeadOresInInventory: Int32;
  InactivityTimer, ReportTimer: TStopwatch;
  TotalBreakTime, LastBreakStartTime, LastBreakEndTime: Int64;
  SetMiningAngle: Boolean;
  CurrentZoomLevel: Int32;

procedure WriteDebug(Message: String);
begin
  if VERBOSE_LOGGING then
    WriteLn(SRL.TimeStamp(), ':[LeadMiner]: ', Message);
end;

procedure SetupMapAndWalker();
begin
  Map.SetupChunks([
    Chunk([46,147,48,145], 0),  // Pandemonium Dungeon
    Chunk([46,47,48,45], 0)     // Pandemonium Island surface
  ]);
end;

procedure SetupLeadRocks();
begin
  // Rock 1 at [8140, 12926]
  PandemoniumObjects.LeadRock1.SetupEx([1, 1, 3], [[8140, 12926]]);
  PandemoniumObjects.LeadRock1.SetupUpText(['Lead']);
  PandemoniumObjects.LeadRock1.Finder.Colors += [CTS2(8681099, 8, 3.15, 0.73)];
