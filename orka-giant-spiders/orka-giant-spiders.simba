(**
 * WriteDebug
 *
 * Logs a timestamped verbose debug message, only when VERBOSE_LOGGING is enabled.
 *
 * @param Message  The message to log
 *)
procedure WriteDebug(Message: String);
begin
  if VERBOSE_LOGGING then
    WriteLn(SRL.TimeStamp(), ':[', SCRIPT_NAME, ']: [DEBUG] ', Message);
end;

(**
 * WriteLog
 *
 * Logs a timestamped key-event message that is always visible regardless of VERBOSE_LOGGING.
 *
 * @param Message  The message to log
 *)
procedure WriteLog(Message: String);
begin
  WriteLn(SRL.TimeStamp(), ':[', SCRIPT_NAME, ']: ', Message);
end;

(**
 * FormatNumber
 *
 * Formats an integer with thousand separators (e.g., 125000 -> "125,000").
 *
 * @param n  The number to format
 * @return   Formatted string with commas as thousand separators
 *)
function FormatNumber(n: Int32): String;
var
  s: String;
  i, count: Int32;
begin
  s := IntToStr(Abs(n));
  Result := '';
  count := 0;
  for i := Length(s) downto 1 do
  begin
    if (count > 0) and (count mod 3 = 0) then
      Result := ',' + Result;
    Result := s[i] + Result;
    Inc(count);
  end;
  if n < 0 then
    Result := '-' + Result;
end;

(**
 * SetupMapAndWalker
 *
 * Initializes the map walker with Stronghold of Security and Edgeville map chunks.
 *)
procedure SetupMapAndWalker();
begin
  Map.SetupChunks([
    Chunk([28,83,34,80], 0),  // Stronghold of Security 1st/2nd floor
    Chunk([47,55,51,52], 0)   // Barb Village / Edgeville entrance / Varrock
  ]);

  Objects.Setup(Map.Objects(), @Map.Walker);
  NPCs.Setup(Map.NPCs(), @Map.Walker);

  // Exclude Cooking Guild bank area
  Banks._FilterLocation(
    [[8424, 36590], [8536, 36590], [8536, 36682], [8424, 36682]],
    True
  );
end;

