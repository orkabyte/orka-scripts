const
  SCRIPT_NAME = 'Orka Giant Spiders';
  VERBOSE_LOGGING = True;

  // --- Location tiles ---
  EDGEVILLE_BANK_TILE: TPoint = [8284, 36470];
  AGGRO_RESET_TILE: TPoint = [4376, 29418];
  INITIAL_COMBAT_TILE: TPoint = [4380, 29322];

  // --- Floor transition destination boxes ---
  SURFACE_BOX: TBox = [7988, 36370, 8924, 36858];
  FIRST_FLOOR_BOX: TBox = [3328, 29438, 3380, 29490];
  FIRST_FLOOR_PAST_PORTAL_BOX: TBox = [3492, 29502, 3596, 29598];
  SECOND_FLOOR_BOX: TBox = [4060, 29438, 4100, 29474];
  SECOND_FLOOR_PAST_PORTAL_BOX: TBox = [3936, 29518, 4048, 29626];
  THIRD_FLOOR_BOX: TBox = [4352, 29182, 4608, 29438];

  // --- Gate area destination boxes (3rd floor) ---
  COMBAT_AREA_GATE_BOX: TBox = [4424, 29382, 4444, 29390];
  BETWEEN_GATES_BOX: TBox = [4424, 29394, 4444, 29402];
  BEFORE_GATE1_BOX: TBox = [4364, 29406, 4448, 29434];

  // --- Area detection radii ---
  EDGEVILLE_RADIUS = 300;
  STRONGHOLD_RADIUS = 100;

  // --- Combat timing ---
  COMBAT_TIMEOUT_MIN = 13 * ONE_SECOND;
  COMBAT_TIMEOUT_MAX = 17 * ONE_SECOND;

  // --- Health thresholds ---
  HEAL_HP_MIN = 60;
  HEAL_HP_MAX = 70;

  // --- Potion timing ---
  POTION_TIMER_MIN = 225 * ONE_SECOND;
  POTION_TIMER_MAX = 290 * ONE_SECOND;

  // --- Report ---
  REPORT_FREQUENCY = 5 * ONE_MINUTE;
  REPORT_BANNER_WIDTH = 42;

  // --- Gate behavior ---
  // Controls how Stronghold of Security gate dialogs are handled:
  //   0 = Always brute-force (ignore questions, re-click gate up to 10 times)
  //   1 = BioDice decides per gate (randomly answer or brute-force)
  //   2 = Always answer security questions correctly
  GATE_BEHAVIOR = 1;

  // Chance (%) to intentionally select the wrong answer when in answer mode.
  // Uses SRL.Dice — e.g. 10 = 10% chance to fail each question.
  GATE_FAIL_ANSWER_CHANCE = 10;

