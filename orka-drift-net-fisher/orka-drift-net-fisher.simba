(** Checks the active RuneLite profile for GPU plugin and auto-disables it. *)
procedure DisableGPUPlugin();
var
  profilesDir, content, profileName, profileId: String;
  json, profile: TJSONObject;
  profiles: TJSONArray;
  foundFiles: TStringArray;
  fileName, propsPath, propsContent, output: String;
  i: Int32;
begin
  profilesDir := GetEnvironmentVariable('USERPROFILE') + '\.runelite\profiles2';
  if not FileExists(profilesDir + '\profiles.json') then Exit;

  content := ReadFileContents(profilesDir + '\profiles.json');
  if content = '' then Exit;

  json.Init(content.Trim());
  try
    profiles := json.getJSONArray('profiles');
    for i := 0 to profiles.High() do
    begin
      profile := profiles.getJSONObject(i);
      if profile.has('active') and profile.getBoolean('active') then
      begin
        profileName := profile.getString('name');
        profileId := ToString(Trunc(profile.getDouble('id')));
        Break;
      end;
    end;
  finally
    json.Free();
  end;

  if (profileName = '') or (profileId = '') then Exit;

  foundFiles := FindFiles(profilesDir, False);

  for fileName in foundFiles do
    if ExtractFileName(fileName) = (profileName + '-' + profileId + '.properties') then
    begin
      propsPath := fileName;
      Break;
    end;

  if propsPath = '' then
    for fileName in foundFiles do
      if ExtractFileName(fileName).StartsWith(profileName) and ExtractFileName(fileName).EndsWith('.properties') then
      begin
        propsPath := fileName;
        Break;
      end;

  if propsPath = '' then Exit;

  propsContent := ReadFileContents(propsPath);
  if Pos('runelite.gpuplugin=true', propsContent) = 0 then Exit;

  propsContent := Replace(propsContent, 'runelite.gpuplugin=true', 'runelite.gpuplugin=false', [rfReplaceAll]);
  if WriteFileContents(propsPath, propsContent, False) then
  begin
    WriteLn('GPU Plugin was enabled in profile "' + profileName + '" - disabled automatically.');
    RunCommand('cmd', ['/c', 'taskkill /f /im RuneLite.exe'], output);
    WriteLn('RuneLite closed. Please restart RuneLite and the script.');
    TerminateScript();
  end;
end;

(**
 * WriteLog
 *
 * Always-visible log messages for important operations, errors, warnings.
 *
 * @param msg  Message to log
 *)
procedure WriteLog(msg: String);
begin
  WriteLn(SRL.TimeStamp(), ':[', SCRIPT_NAME, ']: ', msg);
end;

(**
 * WriteDebug
 *
 * Verbose debug messages only shown when VERBOSE_LOGGING is True.
 *
 * @param msg  Message to log
 *)
procedure WriteDebug(msg: String);
begin
  if VERBOSE_LOGGING then
    WriteLn(SRL.TimeStamp(), ':[', SCRIPT_NAME, ']: [DEBUG] ', msg);
end;

(**
 * FormatNumber
 *
 * Formats an integer with thousand separators (e.g., 125000 -> "125,000").
 *
 * @param n  The number to format
 * @return   Formatted string with commas as thousand separators
 *)
function FormatNumber(n: Int64): String;
var
  s: String;
  i, count: Int32;
begin
  s := IntToStr(Abs(n));
  Result := '';
  count := 0;
  for i := Length(s) downto 1 do
  begin
    if (count > 0) and (count mod 3 = 0) then
      Result := ',' + Result;
    Result := s[i] + Result;
    Inc(count);
  end;
  if n < 0 then
    Result := '-' + Result;
end;

